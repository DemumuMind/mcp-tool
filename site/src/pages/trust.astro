---
import PageHero from "../components/PageHero.astro";
import Base from "../layouts/Base.astro";
import GlossaryTerm from "../components/GlossaryTerm.astro";
import ReceiptLink from "../components/ReceiptLink.astro";
import { kit } from "../lib/kit";
import fs from "node:fs";
import path from "node:path";
import { withBase } from "../lib/site-paths";

const title = `Trust Center - ${kit.site.title || "DemumuMind"}`;
const description = `How ${kit.site.title || "DemumuMind"} earns trust: receipts, hashed inputs, freeze modes, drift detection, and independent verification.`;

let buildMeta: any = {};
const buildPath = path.join(process.cwd(), "public/_build.json");
try {
  if (fs.existsSync(buildPath)) {
    buildMeta = JSON.parse(fs.readFileSync(buildPath, "utf8"));
  }
} catch {}

let provenClaimCount = 0;
const toolsDir = path.join(process.cwd(), "src/data/marketir/data/tools");
try {
  if (fs.existsSync(toolsDir)) {
    const files = fs.readdirSync(toolsDir).filter((file: string) => file.endsWith(".json"));
    for (const file of files) {
      const tool = JSON.parse(fs.readFileSync(path.join(toolsDir, file), "utf8"));
      if (!tool.claims) continue;
      provenClaimCount += tool.claims.filter((claim: any) => claim.status === "proven").length;
    }
  }
} catch {}

let trustReceipt: any = {};
const trustPath = path.join(process.cwd(), "public/trust.json");
try {
  if (fs.existsSync(trustPath)) {
    trustReceipt = JSON.parse(fs.readFileSync(trustPath, "utf8"));
  }
} catch {}

let governance: any = {};
const governancePath = path.join(process.cwd(), "src/data/governance.json");
try {
  if (fs.existsSync(governancePath)) {
    governance = JSON.parse(fs.readFileSync(governancePath, "utf8"));
  }
} catch {}

let worthyCriteria: string[] = [];
let worthyMinScore = 0;
const worthyPath = path.join(process.cwd(), "src/data/worthy.json");
try {
  if (fs.existsSync(worthyPath)) {
    const worthy = JSON.parse(fs.readFileSync(worthyPath, "utf8"));
    worthyCriteria = worthy.rubric?.criteria || [];
    worthyMinScore = worthy.rubric?.minimumScore || 0;
  }
} catch {}

let latestWeek: string | null = null;
const outreachDir = path.join(process.cwd(), "public/outreach-run");
try {
  if (fs.existsSync(outreachDir)) {
    const entries = fs.readdirSync(outreachDir, { withFileTypes: true });
    const weeks = entries
      .filter((entry: any) => entry.isDirectory() && /^\d{4}-\d{2}-\d{2}$/.test(entry.name))
      .map((entry: any) => entry.name)
      .sort()
      .reverse();
    latestWeek = weeks[0] || null;
  }
} catch {}

const projectCount = buildMeta.projects || 0;
const artifactCount = trustReceipt.artifactManifest ? Object.keys(trustReceipt.artifactManifest).length : 0;
const commitSha = trustReceipt.commit || null;
const decisionsFrozen = governance.decisionsFrozen === true;
const experimentsFrozen = governance.experimentsFrozen === true;
---

<Base title={title} description={description} currentPath="/trust/">
  <div class="trust-page">
    <PageHero
      eyebrow="Trust center"
      title="Evidence first. Promotion second."
      lede="Receipts, hashes, freeze controls, and reproducible inputs make every public promotion inspectable."
      meta={[
        `${artifactCount || 0} hashed artifacts`,
        `${provenClaimCount || 0} proven claims`,
        `${projectCount || 0} tracked projects`,
      ]}
    >
      <Fragment slot="actions">
        <a href={withBase("/receipts/")} class="btn btn-primary">Browse receipts</a>
        <a href="#verify" class="btn btn-secondary">Verify a week</a>
      </Fragment>
    </PageHero>

    <nav class="trust-path" aria-label="Trust verification path">
      <a href={withBase("/press/")}>Press</a>
      <span>-></span>
      <span>Trust</span>
      <span>-></span>
      <a href={withBase("/receipts/")}>Receipts</a>
      <span>-></span>
      {latestWeek ? <a href={withBase(`/promo/${latestWeek}/`)}>Latest week</a> : <span>Promo week</span>}
      <span>-></span>
      <a href="#verify">Verify</a>
    </nav>

    <section class="trust-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Trust model</p>
          <h2 class="section-shell__title">What we mean by trust</h2>
        </div>
      </div>
      <p>
        Every public promotion is backed by a{" "}
        <GlossaryTerm term="receipt" definition="A JSON file listing hashed inputs, the generating commit, and timestamps for a specific promotion week." />.
        Receipts show inputs, decision context, and the commit that generated the public surface.
      </p>
      <div class="freshness-grid">
        {artifactCount > 0 && (
          <div class="freshness-item">
            <span class="freshness-label">Artifacts hashed</span>
            <span class="freshness-value">{artifactCount}</span>
          </div>
        )}
        {provenClaimCount > 0 && (
          <div class="freshness-item">
            <span class="freshness-label">Proven claims</span>
            <span class="freshness-value">{provenClaimCount}</span>
          </div>
        )}
        {commitSha && commitSha !== "unknown" && (
          <div class="freshness-item">
            <span class="freshness-label">Build commit</span>
            <span class="freshness-value mono">
              <a href={`https://github.com/${kit.repo.marketing || "DemumuMind/mcp-tool"}/commit/${commitSha}`} rel="noopener">{commitSha.slice(0, 8)}</a>
            </span>
          </div>
        )}
        {projectCount > 0 && (
          <div class="freshness-item">
            <span class="freshness-label">Projects tracked</span>
            <span class="freshness-value">{projectCount}</span>
          </div>
        )}
      </div>
    </section>

    <section class="trust-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Promotion logic</p>
          <h2 class="section-shell__title">How a promo gets published</h2>
        </div>
      </div>
      <ol class="pipeline-steps">
        <li><strong>Score.</strong> The <GlossaryTerm term="worthiness rubric" definition="A checklist that scores tools on documentation, tests, releases, and other quality signals." /> rates each tool on evidence-backed criteria.</li>
        <li><strong>Queue.</strong> A human adds qualifying slugs to the weekly promotion queue.</li>
        <li><strong>Generate.</strong> The pipeline builds press surfaces, proof pages, and receipts from hashed inputs.</li>
        <li><strong>Publish.</strong> A human reviews the PR, merges it, and the site deploys.</li>
      </ol>
      {worthyCriteria.length > 0 && (
        <div class="rubric-list">
          <p class="rubric-heading">Worthiness criteria (minimum score: {worthyMinScore}/{worthyCriteria.length})</p>
          <ul>
            {worthyCriteria.map((criterion: string) => <li>{criterion}</li>)}
          </ul>
        </div>
      )}
    </section>

    <section class="trust-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Governance</p>
          <h2 class="section-shell__title">Freeze controls</h2>
        </div>
      </div>
      <p>
        When decisions or experiments are frozen, the system still builds and audits the site, but no new automated recommendations graduate without human intervention.
      </p>
      <div class="freeze-grid">
        <div class:list={["freeze-item", decisionsFrozen ? "frozen" : "active"]}>
          <span class="freeze-indicator"></span>
          <div>
            <span class="freeze-label">Decisions</span>
            <span class="freeze-state">{decisionsFrozen ? "Frozen" : "Active"}</span>
          </div>
        </div>
        <div class:list={["freeze-item", experimentsFrozen ? "frozen" : "active"]}>
          <span class="freeze-indicator"></span>
          <div>
            <span class="freeze-label">Experiments</span>
            <span class="freeze-state">{experimentsFrozen ? "Frozen" : "Active"}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="trust-section" id="verify">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Verification recipe</p>
          <h2 class="section-shell__title">How to verify a promotion week</h2>
        </div>
      </div>
      <div class="verify-recipe">
        <ol>
          <li>Open the promotion week page and copy the verification bundle.</li>
          <li>Check out the commit SHA listed in the bundle.</li>
          <li>Run <code>sha256sum</code> on each input file from the bundle.</li>
          <li>Compare the resulting hashes to the recorded hashes.</li>
        </ol>
      </div>
      {latestWeek ? (
        <p><ReceiptLink href={`/promo/${latestWeek}/`} label="See the latest week" /></p>
      ) : (
        <p>No promotion weeks are available yet.</p>
      )}
    </section>
  </div>
</Base>

<style>
  .trust-page {
    display: grid;
    gap: 1.5rem;
  }

  .trust-section {
    display: grid;
    gap: 1rem;
  }

  .pipeline-steps {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-text-muted);
  }

  .pipeline-steps li + li {
    margin-top: 0.45rem;
  }

  .rubric-heading {
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .freeze-item.active .freeze-indicator {
    background: var(--color-success);
  }

  .freeze-item.frozen .freeze-indicator {
    background: var(--color-warning);
  }

  .freeze-indicator {
    display: inline-block;
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
  }

  .freeze-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .freeze-state {
    display: block;
    color: var(--color-text);
    font-size: 0.95rem;
  }
</style>
