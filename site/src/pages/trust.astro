---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { withBase } from "../lib/site-paths";
---

<Base title="Trust Reference - DemumuMind MCP" description="Marketplace trust reference for quality signals, methodology, and verification posture." currentPath="/trust/">
  <div class="page-content">
    <PageHero
      eyebrow="Trust reference"
      title="How the marketplace thinks about trust."
      lede="This page explains where trust cues come from, how verified status is framed, and which live pages you should use when you want evidence instead of claims."
      meta={["Signals explained", "Verified explained", "Methodology-linked"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-secondary">Browse tools</a>
        <a href={withBase("/methodology/")} class="btn btn-primary">Open methodology</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Open stats</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">What moved</p>
          <h2 class="section-shell__title">Trust cues now live in the main marketplace pages</h2>
        </div>
      </div>
      <ul class="ops-list">
        <li>Browse cards carry quality score, verified status, freshness, and compatibility cues.</li>
        <li>Tool dossiers expose adoption path, transports, runtime fit, and score breakdown.</li>
        <li>Methodology explains the scoring and automatic verified logic directly.</li>
      </ul>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Where to verify</p>
          <h2 class="section-shell__title">Use the live pages that carry the evidence</h2>
        </div>
      </div>
      <div class="platform-hub-grid">
        <a href={withBase("/methodology/")} class="collection-item">
          <span class="collection-item-name">Methodology</span>
          <span class="collection-item-desc">How quality score, listing bar, compatibility, and automatic verified work.</span>
        </a>
        <a href={withBase("/stats/")} class="collection-item">
          <span class="collection-item-name">Stats</span>
          <span class="collection-item-desc">Marketplace health, verification coverage, category depth, and platform reach.</span>
        </a>
        <a href={withBase("/tools/")} class="collection-item">
          <span class="collection-item-name">Browse Tools</span>
          <span class="collection-item-desc">See trust cues where they matter: in the actual discovery and adoption flow.</span>
        </a>
      </div>
    </section>
  </div>
</Base>
