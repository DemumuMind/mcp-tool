---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import releases from "../../data/releases.json";
import { withBase } from "../../lib/site-paths";

function timeAgo(iso: string) {
  if (!iso) return "";
  const seconds = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
  if (seconds < 60) return "just now";
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  return new Date(iso).toLocaleDateString();
}
---

<Base title="Release Reference - DemumuMind MCP" description="Secondary release reference for tools listed in the MCP marketplace." currentPath="/releases/">
  <div class="page-content">
    <PageHero
      eyebrow="Reference surface"
      title="Marketplace release reference"
      lede="Release history remains available as a secondary reference surface for operators who want freshness context after they discover a tool."
      meta={[`${(releases as any[]).length} release entries`, "Reference surface", "Marketplace-linked"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Open stats</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
      </Fragment>
    </PageHero>

    <div class="release-feed">
      {(releases as any[]).map((release: any) => (
        <article class="release-entry">
          <div class="release-header">
            <a href={withBase(`/tools/${release.repo}/`)} class="release-tool">{release.toolName}</a>
            <span class="release-tag">{release.tag}</span>
            <time class="release-date" datetime={release.publishedAt}>{timeAgo(release.publishedAt)}</time>
          </div>
          {release.name && <p class="release-name">{release.name}</p>}
        </article>
      ))}
    </div>
  </div>
</Base>
