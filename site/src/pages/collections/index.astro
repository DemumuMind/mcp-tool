---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import { getMarketplaceContent } from "../../lib/content/marketplace.ts";
import { withBase } from "../../lib/site-paths";

const content = getMarketplaceContent();
const formatNumber = (value: number) => new Intl.NumberFormat("en-US").format(value);
---

<Base title="Collections - DemumuMind MCP" description="Curated collections that group MCP tools into useful starting sets." currentPath="/collections/">
  <div class="page-content">
    <PageHero
      eyebrow="Collections"
      title="Curated tool sets for faster shortlists."
      lede="Use collections when you want a smaller, opinionated set of MCP tools instead of starting from the full catalog."
      meta={[`${formatNumber(content.collections.length)} collections`, "Curated shortlists", "Built from live listings"]}
    />

    <div class="platform-hub-grid">
      {content.collections.map((collection) => (
        <a href={withBase(`/collections/${collection.slug}/`)} class="collection-item">
          <span class="collection-item-name">{collection.title}</span>
          <span class="collection-item-desc">{collection.description}</span>
          <span class="collection-item-count">{formatNumber(collection.count)} tools in set</span>
        </a>
      ))}
    </div>
  </div>
</Base>
