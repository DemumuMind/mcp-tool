---
export const prerender = true;

import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import GlossaryTerm from "../../components/GlossaryTerm.astro";
import { kit } from "../../lib/kit";
import fs from "node:fs";
import path from "node:path";
import { withBase } from "../../lib/site-paths";

let worthyCriteria: string[] = [];
let worthyMinScore = 0;
const worthyPath = path.join(process.cwd(), "src/data/worthy.json");
try {
  if (fs.existsSync(worthyPath)) {
    const worthy = JSON.parse(fs.readFileSync(worthyPath, "utf8"));
    worthyCriteria = worthy.rubric?.criteria || [];
    worthyMinScore = worthy.rubric?.minimumScore || 0;
  }
} catch {}

const exampleJson = JSON.stringify(
  {
    tool: { name: "My Tool", slug: "my-tool", repo: "https://github.com/org/my-tool" },
    category: "devtools",
    kind: "cli",
    pitch: "A short description of what the tool does and why it matters.",
    goodFor: ["Use case one", "Use case two"],
    notFor: ["Not intended for this"],
    proof: [{ label: "CI", url: "https://github.com/org/my-tool/actions", whatItProves: "Tests pass" }],
    install: "npm install -g my-tool",
    quickstart: "my-tool init",
    maintainer: { handle: "@you" },
    submission: {
      lane: "promo",
      submittedAt: "2026-03-17T09:00:00Z",
      pr: "https://github.com/org/marketing-repo/pull/42",
    },
  },
  null,
  2
);
---

<Base title={`Get Featured - ${kit.site.title || "DemumuMind"}`} description={`Submit your tool for promotion or experimentation on the ${kit.site.title || "DemumuMind"} catalog.`} currentPath="/submit/">
  <div class="submit-page">
    <PageHero
      eyebrow="Submission guide"
      title="Submit a tool with enough proof to review it."
      lede="Submissions start from a structured intake file, CI validation, and a human review pass. The public queue only mirrors safe status updates after review."
      meta={["Weekly review cycle", "Proof required", "Two submission paths"]}
    />

    <section class="submit-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Qualification</p>
          <h2 class="section-shell__title">What qualifies for review</h2>
        </div>
      </div>
      <p>
        A new visitor should be able to install and run the tool, understand its limits, and inspect at least one proof link.
      </p>
      {worthyCriteria.length > 0 && (
        <div class="rubric-list">
          <p class="rubric-heading">
            Our <GlossaryTerm term="worthiness rubric" definition="A checklist that scores tools on documentation, tests, releases, and other quality signals." /> requires at least {worthyMinScore}/{worthyCriteria.length}.
          </p>
          <ul>
            {worthyCriteria.map((criterion: string) => <li>{criterion}</li>)}
          </ul>
        </div>
      )}
    </section>

    <section class="submit-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Disqualifiers</p>
          <h2 class="section-shell__title">What gets rejected quickly</h2>
        </div>
      </div>
      <ul class="disqualify-list">
        <li>No install path or unclear runtime requirements.</li>
        <li>"Coming soon" repos with no working code.</li>
        <li>No license or claims with no evidence.</li>
        <li>Tools already present in the <a href={withBase("/tools/")}>catalog</a>.</li>
      </ul>
    </section>

    <section class="submit-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Submission flow</p>
          <h2 class="section-shell__title">How to submit</h2>
        </div>
      </div>
      <div class="steps-box">
        <ol>
          <li>Fork the <a href={`https://github.com/${kit.repo.marketing || "DemumuMind/mcp-tool"}`} rel="noopener" data-link-type="fork">marketing repo</a>.</li>
          <li>Create <code>submissions/&lt;your-slug&gt;.json</code> with the public submission metadata, including <code>submission.lane</code>.</li>
          <li>Open the promotion or experiment pull request template and wait for CI validation.</li>
          <li>CI projects the public queue row into <code>site/src/data/submissions.json</code>; maintainers patch only review status there.</li>
        </ol>
      </div>
    </section>

    <section class="submit-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Submission schema</p>
          <h2 class="section-shell__title">Required shape</h2>
        </div>
      </div>
      <div class="schema-block">
        <pre><code>{exampleJson}</code></pre>
      </div>
    </section>

    <section class="submit-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Two lanes</p>
          <h2 class="section-shell__title">Choose a submission path</h2>
        </div>
      </div>
      <div class="lanes-grid">
        <div class="lane-card">
          <h3>Promotion</h3>
          <p>Tools that clear the rubric move into the public promotion pipeline with proof pages, press coverage, and receipts.</p>
        </div>
        <div class="lane-card">
          <h3>Experiment</h3>
          <p>Earlier tools can enter the experiment lane for controlled copy testing before they graduate to a public push.</p>
        </div>
      </div>
    </section>

    <section class="submit-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Review policy</p>
          <h2 class="section-shell__title">What happens after CI</h2>
        </div>
      </div>
      <ul class="policy-list">
        <li>Submissions are reviewed on a weekly cadence.</li>
        <li>Entries may be marked <strong>needs info</strong> while details are clarified.</li>
        <li>The public queue shows only status-safe updates, not reviewer-only notes or internal escalation details.</li>
      </ul>
    </section>
  </div>
</Base>

<script>
  import { trackEvent } from "../../lib/tracker";

  document.querySelectorAll("[data-link-type]").forEach((link) => {
    link.addEventListener("click", () => {
      const linkType = link.dataset.linkType || "";
      trackEvent("click_submit_link", { linkType });
    });
  });
</script>
