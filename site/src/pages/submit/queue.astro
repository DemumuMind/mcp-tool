---
export const prerender = true;

import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import { kit } from "../../lib/kit";
import fs from "node:fs";
import path from "node:path";
import { withBase } from "../../lib/site-paths";

const title = `Submission Queue - ${kit.site.title || "DemumuMind"}`;
const description = "Track the status of tool submissions for promotion and experimentation.";
const adminSubmissionsUrl = String(import.meta.env.PUBLIC_ADMIN_URL || "").trim().replace(/\/$/, "")
  ? `${String(import.meta.env.PUBLIC_ADMIN_URL || "").trim().replace(/\/$/, "")}/submissions/`
  : "";

let submissions = [];
const submissionsPath = path.join(process.cwd(), "src/data/submissions.json");

try {
  if (fs.existsSync(submissionsPath)) {
    const data = JSON.parse(fs.readFileSync(submissionsPath, "utf8"));
    submissions = data.submissions || [];
  }
} catch {}

const byStatus = {
  pending: submissions.filter((submission) => submission.status === "pending"),
  needsInfo: submissions.filter((submission) => submission.status === "needs-info"),
  accepted: submissions.filter((submission) => submission.status === "accepted"),
  rejected: submissions.filter((submission) => submission.status === "rejected"),
  withdrawn: submissions.filter((submission) => submission.status === "withdrawn"),
};

function formatDate(iso) {
  if (!iso) return "";
  return new Date(iso).toISOString().slice(0, 10);
}

function renderCompactRows(items) {
  return items.map((submission) => ({
    slug: submission.slug,
    lane: submission.lane,
    date: formatDate(submission.updatedAt || submission.submittedAt),
    reason: submission.reason || "",
  }));
}
---

<Base title={title} description={description} currentPath="/submit/queue/">
  <div class="queue-page">
    <div class="breadcrumbs">
      <a href={withBase("/submit/")}>Submit</a>
      <span>/</span>
      <span>Queue</span>
    </div>

    <PageHero
      eyebrow="Queue ledger"
      title="Track review status without asking in the dark."
      lede="Promotion and experiment submissions move through a single evidence-first queue with explicit statuses and review notes."
      meta={[
        `${byStatus.pending.length} pending`,
        `${byStatus.needsInfo.length} needs info`,
        `${byStatus.accepted.length} accepted`,
        `${submissions.length} total`,
      ]}
    >
      <Fragment slot="actions">
        <a href={withBase("/submit/")} class="btn btn-primary">Submit a tool</a>
      </Fragment>
    </PageHero>

    {submissions.length === 0 ? (
      <div class="empty-state">
        <p>No submissions yet.</p>
        <p>Be the first and <a href={withBase("/submit/")}>open a submission</a>.</p>
      </div>
    ) : (
      <>
        <section class="section-shell">
          <div class="section-shell__header">
            <div>
              <p class="section-kicker">Queue state</p>
              <h2 class="section-shell__title">Current load</h2>
            </div>
          </div>
          <div class="proof-points">
            <div class="proof-point">
              <span class="number">{byStatus.pending.length}</span>
              <span class="label">Pending</span>
            </div>
            <div class="proof-point">
              <span class="number">{byStatus.needsInfo.length}</span>
              <span class="label">Needs info</span>
            </div>
            <div class="proof-point">
              <span class="number">{byStatus.accepted.length}</span>
              <span class="label">Accepted</span>
            </div>
            <div class="proof-point">
              <span class="number">{byStatus.rejected.length}</span>
              <span class="label">Rejected</span>
            </div>
          </div>
        </section>

        {byStatus.pending.length > 0 && (
          <section class="section-shell">
            <div class="section-shell__header">
              <div>
                <p class="section-kicker">Active queue</p>
                <h2 class="section-shell__title">Pending review</h2>
              </div>
            </div>
            <div class="queue-grid">
              {byStatus.pending.map((submission) => (
                <article class="queue-card">
                  <div class="queue-card__header">
                    <h3>{submission.tool?.name || submission.slug}</h3>
                    <span class={`badge badge-${submission.lane === "promo" ? "registered" : "beta"}`}>{submission.lane}</span>
                  </div>
                  <div class="queue-card__meta">
                    <span class="mono">{submission.slug}</span>
                    {submission.kind && <span class="badge badge-kind">{submission.kind}</span>}
                    {submission.category && <span class="badge badge-kind">{submission.category}</span>}
                  </div>
                  {submission.pitch && <p>{submission.pitch}</p>}
                  <div class="queue-card__footer">
                    <span class="field-hint">Submitted {formatDate(submission.submittedAt)}</span>
                    {submission.pr && <a href={submission.pr} rel="noopener">View PR</a>}
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}

        {byStatus.needsInfo.length > 0 && (
          <section class="section-shell">
            <div class="section-shell__header">
              <div>
                <p class="section-kicker">Review feedback</p>
                <h2 class="section-shell__title">Needs info</h2>
              </div>
            </div>
            <div class="queue-grid">
              {byStatus.needsInfo.map((submission) => (
                <article class="queue-card queue-card--attention">
                  <div class="queue-card__header">
                    <h3>{submission.tool?.name || submission.slug}</h3>
                    <span class={`badge badge-${submission.lane === "promo" ? "registered" : "beta"}`}>{submission.lane}</span>
                  </div>
                  <div class="queue-card__meta">
                    <span class="mono">{submission.slug}</span>
                    {submission.kind && <span class="badge badge-kind">{submission.kind}</span>}
                    {submission.category && <span class="badge badge-kind">{submission.category}</span>}
                  </div>
                  {submission.reviewNotes && (
                    <div class="review-card">
                      <span class="label">Reviewer notes</span>
                      <p>{submission.reviewNotes}</p>
                    </div>
                  )}
                  <div class="queue-card__footer">
                    {submission.lastReviewedAt && <span class="field-hint">Reviewed {formatDate(submission.lastReviewedAt)}</span>}
                    {submission.sourcePr && <a href={submission.sourcePr} rel="noopener">Source PR</a>}
                    {submission.pr && <a href={submission.pr} rel="noopener">View PR</a>}
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}

        {byStatus.accepted.length > 0 && (
          <section class="section-shell">
            <div class="section-shell__header">
              <div>
                <p class="section-kicker">Resolved</p>
                <h2 class="section-shell__title">Accepted</h2>
              </div>
            </div>
            <div class="release-feed">
              {renderCompactRows(byStatus.accepted).map((row) => (
                <div class="release-entry">
                  <span class="release-tool mono">{row.slug}</span>
                  <span class={`badge badge-${row.lane === "promo" ? "registered" : "beta"}`}>{row.lane}</span>
                  <span class="release-date-inline">{row.date}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {byStatus.rejected.length > 0 && (
          <section class="section-shell">
            <div class="section-shell__header">
              <div>
                <p class="section-kicker">Resolved</p>
                <h2 class="section-shell__title">Rejected</h2>
              </div>
            </div>
            <div class="release-feed">
              {renderCompactRows(byStatus.rejected).map((row) => (
                <div class="release-entry">
                  <span class="release-tool mono">{row.slug}</span>
                  <span class={`badge badge-${row.lane === "promo" ? "registered" : "beta"}`}>{row.lane}</span>
                  <span class="release-date-inline">{row.date}</span>
                  {row.reason && <span class="field-hint">{row.reason}</span>}
                </div>
              ))}
            </div>
          </section>
        )}

        {byStatus.withdrawn.length > 0 && (
          <section class="section-shell">
            <div class="section-shell__header">
              <div>
                <p class="section-kicker">Resolved</p>
                <h2 class="section-shell__title">Withdrawn</h2>
              </div>
            </div>
            <div class="release-feed">
              {renderCompactRows(byStatus.withdrawn).map((row) => (
                <div class="release-entry">
                  <span class="release-tool mono">{row.slug}</span>
                  <span class={`badge badge-${row.lane === "promo" ? "registered" : "beta"}`}>{row.lane}</span>
                  <span class="release-date-inline">{row.date}</span>
                </div>
              ))}
            </div>
          </section>
        )}
      </>
    )}

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Provenance</p>
          <h2 class="section-shell__title">Validation path</h2>
        </div>
      </div>
      <div class="steps-box">
        <p>
          Submissions are validated by <code>validate-submissions.mjs</code> on every PR before they reach a human reviewer.
        </p>
        <p>
          Learn the intake contract on <a href={withBase("/submit/")}>Get Featured</a>.
        </p>
        <p>
          {adminSubmissionsUrl ? (
            <>Internal operators should use the <a href={adminSubmissionsUrl}>admin submissions workspace</a> for assignment, SLA escalation, and approval-gated decisions.</>
          ) : (
            <>Internal operator actions run on the private admin host. Configure <code>PUBLIC_ADMIN_URL</code> to expose a direct submissions workspace link from this public queue page.</>
          )}
        </p>
      </div>
    </section>
  </div>
</Base>

<style>
  .queue-page {
    display: grid;
    gap: 1.5rem;
  }

  .queue-grid {
    display: grid;
    gap: 1rem;
  }

  .queue-card {
    display: grid;
    gap: 0.8rem;
    padding: 1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.028), rgba(255, 255, 255, 0.012)),
      var(--color-panel);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: var(--radius-md);
  }

  .queue-card--attention {
    border-color: rgba(217, 107, 59, 0.24);
  }

  .queue-card__header,
  .queue-card__meta,
  .queue-card__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    justify-content: space-between;
  }

  .queue-card__header h3 {
    font-size: 1rem;
  }

  .queue-card__meta,
  .queue-card__footer {
    justify-content: flex-start;
  }

  @media (max-width: 720px) {
    .queue-card__header {
      align-items: flex-start;
      justify-content: flex-start;
    }
  }
</style>
