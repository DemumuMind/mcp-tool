---
export const prerender = true;

import InternalHero from "../../../components/InternalHero.astro";
import Layout from "../../../layouts/Base.astro";
import scoreboardData from "../../../data/audit/scoreboard.json";
import metaFindings from "../../../data/audit/metadata-findings.json";
import realityFindings from "../../../data/audit/reality-findings.json";

const { results } = scoreboardData;

const metaMap = new Map(metaFindings.findings.map((finding) => [finding.repo, finding.issues]));
const realityMap = new Map(realityFindings.findings.map((finding) => [finding.repo, finding.issues]));

const stats = {
  stable: results.filter((result) => result.label === "Stable").length,
  prototype: results.filter((result) => result.label === "Prototype").length,
  deprecated: results.filter((result) => result.label === "Deprecated").length,
  needsWork: results.filter((result) => result.label === "Needs Work").length,
  total: results.length,
};

const rows = results.map((row) => {
  const metaIssues = metaMap.get(row.repo) || [];
  const realityIssues = realityMap.get(row.repo) || [];
  return {
    ...row,
    issues: [...metaIssues, ...realityIssues],
    labelClass: row.label.toLowerCase().replace(/\s+/g, "-"),
  };
});

const lastRun = new Date(scoreboardData.generatedAt).toLocaleString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
});
---

<Layout title="Tool Audit Scoreboard" currentPath="/lab/audit/" routeFamily="ops">
  <div class="ops-page">
    <InternalHero
      badge="Operator Surface"
      eyebrow="Metadata audit"
      title="Tool Audit Scoreboard"
      lede="Registry and reality checks summarized as a scored operator review surface."
      meta={[`${stats.total} tools scanned`, `${stats.stable} stable`, `${stats.needsWork} need work`, `${stats.deprecated} deprecated`]}
    />

    <div class="dashboard-header">
      <div class="title-block">
        <p class="meta">Run {lastRun} | {stats.total} tools scanned</p>
      </div>
      <div class="stats-strip">
        <div class="stat-pill success">
          <span class="label">Stable</span>
          <span class="value">{stats.stable}</span>
        </div>
        <div class="stat-pill neutral">
          <span class="label">Prototype</span>
          <span class="value">{stats.prototype}</span>
        </div>
        <div class="stat-pill warning">
          <span class="label">Needs Work</span>
          <span class="value">{stats.needsWork}</span>
        </div>
        <div class="stat-pill critical">
          <span class="label">Deprecated</span>
          <span class="value">{stats.deprecated}</span>
        </div>
      </div>
    </div>

    <div class="controls">
      <input type="text" id="search" placeholder="Search tools..." class="search-input" />
      <div class="filter-chips">
        <button class="chip active" data-filter="all">All</button>
        <button class="chip success" data-filter="Stable">Stable</button>
        <button class="chip neutral" data-filter="Prototype">Prototype</button>
        <button class="chip warning" data-filter="Needs Work">Needs Work</button>
        <button class="chip critical" data-filter="Deprecated">Deprecated</button>
      </div>
    </div>

    <div class="audit-table">
      <div class="table-header">
        <span>Tool / Repo</span>
        <span>Label</span>
        <span>Score</span>
        <span>Issues</span>
      </div>
      <div class="table-body" id="tool-list">
        {rows.map((row) => (
          <div class="table-row" data-label={row.label} data-repo={row.repo}>
            <div class="col-name">
              <strong>{row.repo}</strong>
            </div>
            <div class="col-label">
              <span class={`badge ${row.labelClass}`}>{row.label}</span>
            </div>
            <div class="col-score">
              <div class="score-ring">{row.score}</div>
            </div>
            <div class="col-issues">
              {row.issues.length === 0 ? (
                <span class="text-muted">No issues found</span>
              ) : (
                <ul class="issue-list">
                  {row.issues.map((issue) => <li>{issue}</li>)}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
      <div id="empty-state" class="empty-state hidden">
        <p>No matches found.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById("search");
  const list = document.getElementById("tool-list");
  const rows = list?.querySelectorAll(".table-row");
  const filters = document.querySelectorAll(".chip");
  const emptyState = document.getElementById("empty-state");

  let currentFilter = "all";
  let currentQuery = "";

  function render() {
    let visibleCount = 0;

    rows?.forEach((row) => {
      const label = row.dataset.label;
      const text = row.dataset.repo.toLowerCase();
      const matchesFilter = currentFilter === "all" || label === currentFilter;
      const matchesSearch = text.includes(currentQuery);

      if (matchesFilter && matchesSearch) {
        row.style.display = "grid";
        visibleCount += 1;
      } else {
        row.style.display = "none";
      }
    });

    if (visibleCount === 0) {
      emptyState?.classList.remove("hidden");
    } else {
      emptyState?.classList.add("hidden");
    }
  }

  filters.forEach((button) => {
    button.addEventListener("click", (event) => {
      filters.forEach((currentButton) => currentButton.classList.remove("active"));
      event.target.classList.add("active");
      currentFilter = event.target.dataset.filter || "all";
      render();
    });
  });

  searchInput?.addEventListener("input", (event) => {
    currentQuery = event.target.value.toLowerCase();
    render();
  });
</script>

<style>
  .dashboard-header {
    margin-bottom: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    min-width: 0;
  }

  .ops-page > *,
  .audit-table,
  .table-body,
  .table-row,
  .col-name,
  .col-label,
  .col-score,
  .col-issues {
    min-width: 0;
  }

  .meta {
    color: var(--color-text-dim);
    font-size: 0.9rem;
    margin: 0;
  }

  .stats-strip {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .stat-pill {
    display: flex;
    flex-direction: column;
    min-width: 100px;
    padding: 0.65rem 0.9rem;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
  }

  .stat-pill .label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family: var(--font-mono);
    color: var(--color-text-dim);
  }

  .stat-pill .value {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-pill.success .value { color: var(--color-success); }
  .stat-pill.warning .value { color: var(--color-warning); }
  .stat-pill.critical .value { color: var(--color-danger); }
  .stat-pill.neutral .value { color: var(--color-system); }

  .controls {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .search-input {
    padding: 0.68rem 0.9rem;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text);
    border-radius: 999px;
    min-width: 250px;
  }

  .search-input:focus {
    outline: none;
    border-color: rgba(215, 255, 63, 0.32);
    box-shadow: 0 0 0 3px rgba(215, 255, 63, 0.08);
  }

  .filter-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .chip {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all 0.2s;
  }

  .chip:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
  }

  .chip.active {
    color: var(--color-text);
  }

  .chip.active[data-filter="Stable"] { background: rgba(120, 197, 140, 0.14); border-color: rgba(120, 197, 140, 0.3); }
  .chip.active[data-filter="Prototype"] { background: rgba(122, 141, 255, 0.14); border-color: rgba(122, 141, 255, 0.3); }
  .chip.active[data-filter="Needs Work"] { background: rgba(217, 107, 59, 0.14); border-color: rgba(217, 107, 59, 0.3); }
  .chip.active[data-filter="Deprecated"] { background: rgba(220, 106, 88, 0.14); border-color: rgba(220, 106, 88, 0.3); }
  .chip.active[data-filter="all"] { background: rgba(255, 255, 255, 0.08); }

  .audit-table {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .table-header {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr) minmax(0, 3fr);
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-weight: 600;
    color: var(--color-text-dim);
    text-transform: uppercase;
    font-size: 0.74rem;
    font-family: var(--font-mono);
    letter-spacing: 0.12em;
  }

  .table-row {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr) minmax(0, 3fr);
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    align-items: flex-start;
    gap: 1rem;
  }

  .table-row:last-child { border-bottom: none; }
  .table-row:hover { background: rgba(255, 255, 255, 0.03); }

  .col-name strong {
    color: var(--color-text);
    font-size: 1rem;
  }

  .badge {
    display: inline-flex;
    padding: 0.16rem 0.55rem;
    border-radius: 999px;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .badge.stable { color: var(--color-success); border: 1px solid rgba(120, 197, 140, 0.3); background: rgba(120, 197, 140, 0.12); }
  .badge.prototype { color: var(--color-system); border: 1px solid rgba(122, 141, 255, 0.3); background: rgba(122, 141, 255, 0.12); }
  .badge.needs-work { color: var(--color-warning); border: 1px solid rgba(217, 107, 59, 0.3); background: rgba(217, 107, 59, 0.12); }
  .badge.deprecated { color: var(--color-danger); border: 1px solid rgba(220, 106, 88, 0.3); background: rgba(220, 106, 88, 0.12); }

  .col-score {
    display: flex;
    align-items: center;
  }

  .score-ring {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.6rem;
    min-height: 2.6rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1;
  }

  .issue-list {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .text-muted {
    color: var(--color-text-dim);
    font-size: 0.85rem;
    font-style: italic;
  }

  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--color-text-dim);
  }

  .hidden { display: none; }

  @media (max-width: 768px) {
    .table-header { display: none; }
    .table-row { grid-template-columns: 1fr; gap: 0.75rem; padding: 1.25rem; }
    .controls { flex-direction: column; }
    .search-input { width: 100%; min-width: 0; }
    .filter-chips { width: 100%; }
    .col-score { justify-self: start; }
  }
</style>
