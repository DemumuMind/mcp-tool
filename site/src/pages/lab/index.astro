---
export const prerender = false;

import InternalHero from "../../components/InternalHero.astro";
import Layout from "../../layouts/Base.astro";
import { withBase } from "../../lib/site-paths";

const adminUrl = String(import.meta.env.PUBLIC_ADMIN_URL || "").trim().replace(/\/$/, "");

const LAB_SECTIONS = [
  {
    id: "quality",
    title: "Quality & Compliance",
    items: [
      { href: "/lab/audit/", code: "AUD", title: "Audit Scoreboard", desc: "Tool metadata accuracy and validation status", badge: "Live" },
      { href: "/lab/health/", code: "DOC", title: "README Health", desc: "Content quality analysis for tool documentation", badge: "Live" },
      { href: "/lab/clearance/", code: "CLR", title: "Safety Clearance", desc: "Security and safety compliance checks", badge: "Internal" },
    ],
  },
  {
    id: "pipeline",
    title: "Pipeline Monitoring",
    items: [
      { href: "/lab/baseline/", code: "BAS", title: "Baseline Performance", desc: "Benchmarks and regression testing", badge: "Internal" },
      { href: "/lab/drift/", code: "DRF", title: "Drift Detection", desc: "Configuration and infrastructure drift analysis", badge: "Internal" },
      { href: "/lab/ops/", code: "OPS", title: "Ops History", desc: "Pipeline execution logs and success rates", badge: "Internal" },
      { href: "/lab/telemetry-export/", code: "TEL", title: "Telemetry", desc: "Raw data retention and export", badge: "Internal" },
    ],
  },
  {
    id: "governance",
    title: "Governance & Promotion",
    items: [
      { href: adminUrl || "/lab/control/", code: "ADM", title: "Admin Control Plane", desc: adminUrl ? "Role-aware backoffice for approvals, releases, moderation, and operator queues" : "Internal backoffice lives on a separate runtime. Use the control surface from the public lab until an admin host is configured.", badge: "Internal", external: Boolean(adminUrl) },
      { href: "/lab/control/", code: "CTL", title: "Control Surface", desc: "Operator actions for governance and promotion", badge: "Internal" },
      { href: "/lab/promo/", code: "PRM", title: "Promotion Track", desc: "Active promotion campaigns and status", badge: "Internal" },
      { href: "/lab/worthy/", code: "WRT", title: "Worthy Candidates", desc: "Tools flagged for potential promotion", badge: "Internal" },
      { href: "/lab/queue/", code: "QUE", title: "Queue", desc: "Pending review and processing queue", badge: "Internal" },
    ],
  },
  {
    id: "instruments",
    title: "Live Instruments",
    items: [
      { href: "https://github.com/DemumuMind/vocal-synth-engine", code: "VOC", title: "Vocal Synth Cockpit", desc: "Piano roll, render bank, and A/B comparison for the vocal synthesis engine", badge: "Lab", external: true },
    ],
  },
  {
    id: "intel",
    title: "Market Intelligence",
    items: [
      { href: "https://demumumind.github.io/registry-stats/dashboard/", code: "REG", title: "Registry Pulse", desc: "Weekly download stats, growth pulse, and data health across npm, PyPI, VS Code, NuGet, and Docker Hub", badge: "Live", external: true },
      { href: "/lab/marketir/", code: "MIR", title: "Market IR", desc: "Investor relations and market analysis", badge: "Internal" },
      { href: "/lab/metrics/", code: "MET", title: "Growth Metrics", desc: "User adoption and catalog growth stats", badge: "Internal" },
      { href: "/lab/signals/", code: "SIG", title: "Signals", desc: "Early warning indicators and trends", badge: "Internal" },
      { href: "/lab/targets/", code: "TGT", title: "Targets", desc: "Strategic acquisition and integration targets", badge: "Internal" },
    ],
  },
];
---

<Layout title="The Lab" description="Experimental tools, dashboards, and internal utilities for managing DemumuMind." currentPath="/lab/" routeFamily="ops">
  <div class="ops-page">
    <InternalHero
      badge="Operator Surface"
      eyebrow="Lab console"
      title="The Lab"
      lede="Experimental dashboards, audit rooms, and pipeline controls for the DemumuMind operating surface."
      meta={["Quality and compliance", "Pipeline monitoring", "Promotion governance", "Market intelligence"]}
    />

    {LAB_SECTIONS.map((section) => (
      <section class="ops-section reveal-stage" aria-labelledby={section.id}>
        <div class="ops-section-header">
          <div>
            <span class="ops-kicker">Subsystem</span>
            <h2 id={section.id}>{section.title}</h2>
          </div>
        </div>

        <div class="ops-card-grid">
          {section.items.map((item) => (
            <a class="ops-card ops-link-card" href={item.external ? item.href : withBase(item.href)} {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}>
              <div class="ops-link-card__header">
                <div class="ops-link-card__title">
                  <span class="ops-link-card__code">{item.code}</span>
                  <span>{item.title}</span>
                </div>
                <span class:list={["ops-pill", item.badge === "Live" ? "ops-pill--ok" : item.badge === "Lab" ? "ops-pill--sys" : "ops-pill--warn"]}>{item.badge}</span>
              </div>
              <p class="ops-muted">{item.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}

    <p class="ops-caption">{adminUrl ? "Use the configured admin host for the full backoffice. /lab/ remains the public/internal observability surface for audits, health, and pipeline signals." : "/lab/ remains the public/internal observability surface. Configure PUBLIC_ADMIN_URL to expose a direct link to the private admin host."}</p>
  </div>
</Layout>

<style>
  .ops-link-card {
    text-decoration: none;
    transition: transform 140ms ease, border-color 140ms ease, background-color 140ms ease;
  }

  .ops-link-card:hover {
    transform: translateY(-2px);
    border-color: rgba(122, 141, 255, 0.22);
  }

  .ops-link-card__header {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .ops-link-card__title {
    display: inline-flex;
    gap: 0.65rem;
    align-items: center;
    color: var(--color-text);
    font-weight: 600;
  }

  .ops-link-card__code {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    min-height: 2rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-system);
  }
</style>
