---
export const prerender = true;

import PageHero from "../components/PageHero.astro";
import Base from "../layouts/Base.astro";
import projects from "../data/projects.json";
import { withBase } from "../lib/site-paths";

const popular = (projects as any[]).filter((project: any) => project.featured).slice(0, 5);
---

<Base title="Page not found - DemumuMind" currentPath="/404/" routeFamily="utility">
  <div class="not-found">
    <PageHero
      eyebrow="Fallback"
      title="The route is missing, not the system."
      lede="This page may have moved, been removed, or never existed in the published route map."
      align="center"
    >
      <Fragment slot="actions">
        <a href={withBase("/")} class="btn btn-primary">Go home</a>
        <a href={withBase("/tools/")} class="btn btn-secondary">Browse tools</a>
      </Fragment>
    </PageHero>

    {popular.length > 0 && (
      <div class="popular-tools">
        <h2>Popular tools</h2>
        <ul>
          {popular.map((project: any) => (
            <li>
              <a href={withBase(`/tools/${project.repo}/`)}>{project.name}</a>
              <span class="popular-desc">{project.tagline || project.description}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</Base>

<style>
  .not-found {
    display: grid;
    gap: 1.5rem;
  }

  .popular-tools {
    max-width: 36rem;
    margin: 0 auto;
    text-align: left;
  }

  .popular-tools h2 {
    margin-bottom: 0.85rem;
  }

  .popular-tools ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .popular-tools li {
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
  }
</style>
