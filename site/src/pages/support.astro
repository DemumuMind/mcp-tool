---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { withBase } from "../lib/site-paths";
---

<Base title="Support - DemumuMind MCP" description="Marketplace support reference for issues, docs, submissions, and security reporting." currentPath="/support/">
  <div class="page-content">
    <PageHero
      eyebrow="Marketplace support"
      title="Support reference for the catalog and listed MCP products"
      lede="This page now acts as a marketplace support reference: where to read docs, how to submit tools, and where to route bugs or security concerns."
      meta={["Marketplace support", "Docs first", "Submission-aware"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/docs/")} class="btn btn-primary">Open docs</a>
        <a href={withBase("/submit/")} class="btn btn-secondary">Submit a tool</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Open stats</a>
      </Fragment>
    </PageHero>

    <ul class="ops-list">
      <li>Use the marketplace docs to understand ranking, verification, compatibility, and submission policy.</li>
      <li>Use submit and request-category for catalog changes, not support issues.</li>
      <li>For tool-specific bugs, go to the linked product homepage or repository from the dossier page.</li>
      <li>For security-sensitive issues, use private vendor or repository security reporting, not public comments.</li>
    </ul>
  </div>
</Base>
