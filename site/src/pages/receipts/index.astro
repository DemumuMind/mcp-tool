---
import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import ProofBadge from "../../components/ProofBadge.astro";
import ReceiptLink from "../../components/ReceiptLink.astro";
import fs from "node:fs";
import path from "node:path";
import { withBase } from "../../lib/site-paths";

interface WeekEntry {
  week: string;
  itemCount: number;
  hasReceipt: boolean;
  hasCommit: boolean;
  hasInputHashes: boolean;
  generatedAt: string | null;
}

const weeks: WeekEntry[] = [];
const outreachDir = path.join(process.cwd(), "public/outreach-run");

try {
  if (fs.existsSync(outreachDir)) {
    const entries = fs.readdirSync(outreachDir, { withFileTypes: true });
    for (const entry of entries) {
      if (!entry.isDirectory() || !/^\d{4}-\d{2}-\d{2}$/.test(entry.name)) continue;

      const weekDir = path.join(outreachDir, entry.name);
      let outreachRun: any = null;
      let receipt: any = null;

      try {
        const runPath = path.join(weekDir, "outreach-run.json");
        if (fs.existsSync(runPath)) outreachRun = JSON.parse(fs.readFileSync(runPath, "utf8"));
      } catch {}

      try {
        const receiptPath = path.join(weekDir, "promo-week-receipt.json");
        if (fs.existsSync(receiptPath)) receipt = JSON.parse(fs.readFileSync(receiptPath, "utf8"));
      } catch {}

      if (!outreachRun && !receipt) continue;

      weeks.push({
        week: entry.name,
        itemCount: outreachRun?.items?.length || 0,
        hasReceipt: receipt !== null,
        hasCommit: Boolean(receipt?.inputs?.commitSha || receipt?.trustReceiptHash),
        hasInputHashes: Boolean(receipt?.inputs?.promoDecisionsSha),
        generatedAt: outreachRun?.generatedAt || receipt?.generatedAt || null,
      });
    }
  }
} catch {}

weeks.sort((a, b) => b.week.localeCompare(a.week));
---

<Base
  title="Receipt Reference - DemumuMind MCP"
  description="Secondary operational receipts for marketplace promotion weeks."
  currentPath="/receipts/"
>
  <div class="page-content receipts-page">
    <PageHero
      eyebrow="Receipts"
      title="Operational receipts for marketplace promotion weeks."
      lede="Weekly receipts document outbound promotion inputs and hashes. They are useful audit records, but discovery and evaluation should still happen in tools, stats, categories, and methodology."
      meta={[`${weeks.length} receipt weeks`, "Operational receipts", "Marketplace-linked"]}
      asideTitle="What receipts are not"
      asideBody="A receipt shows what entered an outbound workflow. It is not a ranking page and it does not replace a tool page."
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Open stats</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">How to use this surface</p>
          <h2 class="section-shell__title">Verify outbound runs, then return to the marketplace</h2>
        </div>
      </div>
      <ul class="ops-list">
        <li>Use tool dossiers, compare pages, and browse filters for product decisions.</li>
          <li>Use receipt weeks when you need hashed inputs, receipt files, and audit-style promotion context.</li>
          <li>Use stats and methodology for the marketplace-wide explanation behind these records.</li>
      </ul>
    </section>

    {weeks.length === 0 ? (
      <div class="empty-state">
        <p>No promotion receipts exist yet.</p>
      </div>
    ) : (
      <div class="weeks-list">
        {weeks.map((week) => (
          <article class="week-card">
            <div class="week-header">
              <a href={withBase(`/promo/${week.week}/`)} class="week-date">{week.week}</a>
              <span class="week-count">{week.itemCount} {week.itemCount === 1 ? "listing" : "listings"}</span>
            </div>
            <div class="week-badges">
              {week.hasReceipt && <ProofBadge type="receipt" />}
              {week.hasInputHashes && <ProofBadge type="hashed" />}
            </div>
            <div class="week-links">
              <a href={withBase(`/promo/${week.week}/`)} class="btn btn-secondary">Open week reference</a>
              {week.hasReceipt && <ReceiptLink href={`/outreach-run/${week.week}/promo-week-receipt.json`} />}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .receipts-page {
    display: grid;
    gap: 1.5rem;
  }
</style>
