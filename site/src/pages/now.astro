---
import PageHero from "../components/PageHero.astro";
import Base from "../layouts/Base.astro";
import { kit } from "../lib/kit";
import { withBase } from "../lib/site-paths";
import fs from "node:fs";
import path from "node:path";

let promoDecisions: any = { decisions: [], generatedAt: null };
try {
  const promoPath = path.join(process.cwd(), "src/data/promo-decisions.json");
  if (fs.existsSync(promoPath)) {
    promoDecisions = JSON.parse(fs.readFileSync(promoPath, "utf8"));
  }
} catch {}

let overrides: any = {};
try {
  const overridesPath = path.join(process.cwd(), "src/data/overrides.json");
  if (fs.existsSync(overridesPath)) {
    overrides = JSON.parse(fs.readFileSync(overridesPath, "utf8"));
  }
} catch {}

const promoted = (promoDecisions.decisions || [])
  .filter((decision: any) => decision.action === "promote")
  .filter((decision: any) => overrides[decision.slug]?.publicProof === true)
  .slice(0, 3);

function loadProofBullets(slug: string): string[] {
  try {
    const toolPath = path.join(process.cwd(), "src/data/marketir/data/tools", `${slug}.json`);
    if (!fs.existsSync(toolPath)) return [];
    const tool = JSON.parse(fs.readFileSync(toolPath, "utf8"));
    return (tool.claims || [])
      .filter((claim: any) => claim.status === "proven")
      .slice(0, 3)
      .map((claim: any) => claim.text || claim.claim || "");
  } catch {
    return [];
  }
}

const featuredTools = promoted.map((decision: any) => {
  const override = overrides[decision.slug] || {};
  return {
    slug: decision.slug,
    tagline: override.tagline || "",
    stability: override.stability || null,
    kind: override.kind || null,
    proofBullets: loadProofBullets(decision.slug),
  };
});

const generatedAt = promoDecisions.generatedAt ? new Date(promoDecisions.generatedAt).toISOString().slice(0, 10) : null;
---

<Base title="Marketplace Focus Reference - DemumuMind MCP" description="Secondary weekly spotlight reference for promoted marketplace listings." currentPath="/now/">
  <div class="page-content now-page">
    <PageHero
      eyebrow="Weekly focus"
      title="This week’s featured marketplace picks."
      lede={`This page highlights the current promoted slice inside ${kit.site.title || "DemumuMind"} with proof and press context attached. Use it as a weekly spotlight, not as the first stop for discovery.`}
      meta={[generatedAt ? `Updated ${generatedAt}` : "Awaiting next run", "Proof-backed picks", "Promotion-linked"]}
      asideTitle="Start with the marketplace"
      asideBody="Browse, compare, and stats remain the primary surfaces. This page is a compact weekly spotlight."
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Open stats</a>
        <a href={withBase("/receipts/")} class="btn btn-secondary">Receipt reference</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">How to use this page</p>
          <h2 class="section-shell__title">Use this page as a spotlight, not a shortlist builder</h2>
        </div>
      </div>
      <ul class="ops-list">
        <li>Use browse or preset pages to build the shortlist.</li>
        <li>Use compare and tool dossiers to make the actual adoption decision.</li>
        <li>Use this page when you want the current promoted slice with proof and press links already attached.</li>
      </ul>
    </section>

    {featuredTools.length === 0 ? (
      <div class="empty-state">
        <p>No featured tools this week.</p>
      </div>
    ) : (
      <div class="tools-grid">
        {featuredTools.map((tool: any) => (
          <article class="tool-card">
            <div class="card-header">
              <h2><a href={withBase(`/tools/${tool.slug}/`)}>{tool.slug}</a></h2>
              <div class="badges">
                {tool.stability && <span class={`badge badge-${tool.stability}`}>{tool.stability}</span>}
                {tool.kind && <span class="badge badge-kind">{tool.kind}</span>}
              </div>
            </div>
            {tool.tagline && <p class="tagline">{tool.tagline}</p>}
            {tool.proofBullets.length > 0 && (
              <ul class="proof-bullets">
                {tool.proofBullets.map((bullet: string) => <li>{bullet}</li>)}
              </ul>
            )}
            <div class="tool-links">
              <a href={withBase(`/tools/${tool.slug}/`)} class="btn btn-secondary">Tool dossier</a>
              <a href={withBase(`/proof/${tool.slug}/`)} class="btn btn-secondary">Proof reference</a>
              <a href={withBase(`/press/${tool.slug}/`)} class="btn btn-secondary">Press reference</a>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .now-page {
    display: grid;
    gap: 1.5rem;
  }

  .card-header,
  .badges {
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .tagline {
    color: var(--color-text-muted);
  }

  .proof-bullets {
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }
</style>
