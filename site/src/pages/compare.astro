---
export const prerender = true;

import Base from "../layouts/Base.astro";
import ComparisonPairCard from "../components/ComparisonPairCard.astro";
import { getCompareHubModel } from "../lib/content/marketplace.ts";
import { withBase } from "../lib/site-paths";

const hub = getCompareHubModel(1);
---

<Base title="Compare MCP Tools - DemumuMind MCP" description="Grouped comparison entry points for the MCP marketplace." currentPath="/compare/">
  <div class="page-content">
    <section class="page-hero">
      <p class="eyebrow">Compare hub</p>
      <h1 class="page-hero__title">Start from useful MCP comparisons.</h1>
      <p class="page-hero__lede">
        Use this hub when you want a shorter path into relevant matchups instead of opening every pair page one by one.
      </p>
      <div class="page-hero__actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        {hub.totalPages > 1 && <a href={withBase("/compare/page/2/")} class="btn btn-secondary">More comparisons</a>}
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Featured pairs</p>
          <h2 class="section-shell__title">Strong places to compare</h2>
        </div>
      </div>
      <div class="featured-tools-grid">
        {hub.featuredPairs.map((pair) => <ComparisonPairCard pair={pair} />)}
      </div>
    </section>

    {hub.groups.map((group) => (
      <section class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">{group.kind === "category" ? "Category hub" : "Platform hub"}</p>
            <h2 class="section-shell__title">{group.title}</h2>
            <p class="section-subheading">{group.description}</p>
          </div>
        </div>
        <div class="featured-tools-grid">
          {group.pairs.map((pair) => <ComparisonPairCard pair={pair} />)}
        </div>
      </section>
    ))}
  </div>
</Base>
