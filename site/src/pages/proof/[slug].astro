---
import Base from "../../layouts/Base.astro";
import overrides from "../../data/overrides.json";
import fs from "node:fs";
import path from "node:path";
import { getProofData, getSnapshotMeta, getToolBySlug, loadSnapshot } from "../../lib/marketir/loader.mjs";
import { withBase } from "../../lib/site-paths";

const overrideMap = overrides as Record<string, any>;

export function getStaticPaths() {
  const overridesBySlug = overrides as Record<string, any>;
  return Object.keys(overridesBySlug)
    .filter((slug) => overridesBySlug[slug]?.publicProof === true)
    .map((slug) => ({
      slug,
      tool: getToolBySlug(slug),
    }))
    .filter(({ tool }) => tool)
    .map(({ slug, tool }) => ({
      params: { slug },
      props: { slug, tool },
    }));
}

const { slug, tool } = Astro.props;
const override = overrideMap[slug] || {};
const proofData = getProofData(slug);
const snapshot = loadSnapshot();
const snapshotMeta = getSnapshotMeta(snapshot);

let facts: any = null;
try {
  const factsPath = path.join(process.cwd(), "src/data/github-facts", `${slug}.json`);
  facts = JSON.parse(fs.readFileSync(factsPath, "utf8"));
} catch {}

let toolLinks: any[] = [];
try {
  const linksPath = path.join(process.cwd(), "src/data/links.json");
  const linksData = JSON.parse(fs.readFileSync(linksPath, "utf8"));
  toolLinks = (linksData.links || []).filter((link: any) => link.slug === slug);
} catch {}

let clearance: any = null;
try {
  const clearancePath = path.join(process.cwd(), "../site/public/lab/clearance", `${slug}.json`);
  clearance = JSON.parse(fs.readFileSync(clearancePath, "utf8"));
} catch {}

const orgUrl = `https://github.com/DemumuMind/${slug}`;
const factsObservedAt = facts?.fetchedAt
  ? new Date(facts.fetchedAt).toLocaleDateString("en-US", { dateStyle: "medium" })
  : null;
const snapshotObservedAt = snapshot?.fetchedAt
  ? new Date(snapshot.fetchedAt).toLocaleDateString("en-US", { dateStyle: "medium" })
  : null;

function getTierLabel(score: number): string {
  if (score >= 80) return "GREEN";
  if (score >= 50) return "YELLOW";
  return "RED";
}
---

<Base title={`${tool.name} - Proof`} description={`Verified claims, evidence chains, and transparency data for ${tool.name}.`} currentPath={`/proof/${slug}/`}>
  <div class="proof-page">
    <a href={withBase("/proof/")} class="back-link">&larr; All proof pages</a>

    <section class="proof-hero">
      <div>
        <p class="eyebrow">Proof dossier</p>
        <h1>{tool.name}</h1>
        <p class="one-liner">{tool.positioning?.oneLiner}</p>
        <div class="badges">
          {override.stability && <span class={`badge badge-${override.stability}`}>{override.stability}</span>}
          {override.kind && <span class="badge badge-kind">{override.kind}</span>}
        </div>
      </div>
      <div class="proof-hero__meta">
        {proofData?.proven?.length > 0 && (
          <div class="meta-block">
            <span class="meta-label">Proven</span>
            <span class="meta-value">{proofData.proven.length}</span>
          </div>
        )}
        {proofData?.aspirational?.length > 0 && (
          <div class="meta-block">
            <span class="meta-label">Aspirational</span>
            <span class="meta-value">{proofData.aspirational.length}</span>
          </div>
        )}
        {proofData?.antiClaims?.length > 0 && (
          <div class="meta-block">
            <span class="meta-label">Anti-claims</span>
            <span class="meta-value">{proofData.antiClaims.length}</span>
          </div>
        )}
      </div>
    </section>

    {proofData?.proven?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Verified record</p>
            <h2 class="section-shell__title">Proven claims</h2>
          </div>
        </div>
        <div class="claims-list">
          {proofData.proven.map((claim: any) => (
            <article class="claim claim-proven">
              <div class="claim-top-row">
                <span class="badge badge-stable">Proven</span>
                <button class="claim-copy-btn" data-claim-text={claim.statement} type="button">Copy</button>
              </div>
              <div class="claim-statement">{claim.statement}</div>
              {claim.evidence?.length > 0 && (
                <div class="claim-evidence">
                  {claim.evidence.map((evidence: any) => (
                    <span class="tag">
                      {evidence.url ? (
                        <a href={evidence.url} target="_blank" rel="noopener">{evidence.type}: {evidence.id.split(".").pop()}</a>
                      ) : evidence.path ? (
                        <a href={withBase(`/marketir/evidence/${evidence.path.split("/").pop()}`)} target="_blank" rel="noopener">{evidence.type}: {evidence.id.split(".").pop()}</a>
                      ) : (
                        <span>{evidence.type}: {evidence.id.split(".").pop()}</span>
                      )}
                    </span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {proofData?.proven?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Copy block</p>
            <h2 class="section-shell__title">Proof bullets</h2>
          </div>
        </div>
        <div class="bullets-container">
          <ul id="proof-bullets-list">
            {proofData.proven.slice(0, 5).map((claim: any) => <li>{claim.statement}</li>)}
          </ul>
          <button class="copy-btn" id="copy-proof-bullets" type="button">Copy all</button>
        </div>
      </section>
    )}

    {proofData?.aspirational?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Not yet proven</p>
            <h2 class="section-shell__title">Aspirational claims</h2>
          </div>
        </div>
        <div class="claims-list">
          {proofData.aspirational.map((claim: any) => (
            <article class="claim">
              <span class="badge badge-beta">Aspirational</span>
              <div class="claim-statement">{claim.statement}</div>
              {claim.notes && <div class="claim-notes">{claim.notes}</div>}
            </article>
          ))}
        </div>
      </section>
    )}

    {proofData?.antiClaims?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Declared limits</p>
            <h2 class="section-shell__title">Anti-claims</h2>
          </div>
        </div>
        <div class="claims-list">
          {proofData.antiClaims.map((claim: any) => (
            <article class="claim">
              <div class="claim-statement">{claim.statement}</div>
            </article>
          ))}
        </div>
      </section>
    )}

    {facts && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Observed facts</p>
            <h2 class="section-shell__title">GitHub facts</h2>
          </div>
        </div>
        <div class="facts-grid">
          {facts.stars != null && <div class="fact"><span class="fact-value">{facts.stars}</span><span class="fact-label">Stars</span></div>}
          {facts.forks != null && <div class="fact"><span class="fact-value">{facts.forks}</span><span class="fact-label">Forks</span></div>}
          {facts.openIssues != null && <div class="fact"><span class="fact-value">{facts.openIssues}</span><span class="fact-label">Open issues</span></div>}
          {facts.releasesLast90d != null && <div class="fact"><span class="fact-value">{facts.releasesLast90d}</span><span class="fact-label">Releases (90d)</span></div>}
          {facts.latestRelease && <div class="fact"><span class="fact-value">{facts.latestRelease.tag}</span><span class="fact-label">Latest release</span></div>}
          {facts.license && <div class="fact"><span class="fact-value">{facts.license}</span><span class="fact-label">License</span></div>}
        </div>
        {factsObservedAt && <p class="observed">Observed {factsObservedAt}. Verify at source if you need authoritative data.</p>}
      </section>
    )}

    {clearance?.overallScore != null && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Operational posture</p>
            <h2 class="section-shell__title">Clearance status</h2>
          </div>
        </div>
        <div class="clearance-card">
          <span class={`badge badge-kind`}>{getTierLabel(clearance.overallScore)}</span>
          <span class="clearance-score">Score: {clearance.overallScore}/100</span>
        </div>
      </section>
    )}

    {toolLinks.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Distribution</p>
            <h2 class="section-shell__title">Tracked links</h2>
          </div>
        </div>
        <div class="links-table-wrap">
          <table class="links-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Channel</th>
                <th>Target</th>
                <th>Campaign</th>
              </tr>
            </thead>
            <tbody>
              {toolLinks.map((link: any) => (
                <tr>
                  <td class="mono">{link.id}</td>
                  <td>{link.channel}</td>
                  <td><a href={link.target} target="_blank" rel="noopener">{link.target.replace("https://", "").slice(0, 40)}{link.target.length > 48 ? "..." : ""}</a></td>
                  <td class="mono">{link.utm?.campaign || "--"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <section class="section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Related surfaces</p>
          <h2 class="section-shell__title">Open next</h2>
        </div>
      </div>
      <div class="related-links">
        {tool.press && <a href={withBase(`/press/${slug}/`)} class="btn btn-secondary">Press page</a>}
        <a href={withBase(`/tools/${slug}/`)} class="btn btn-secondary">Tool page</a>
        <a href={orgUrl} class="btn btn-secondary" target="_blank" rel="noopener">GitHub</a>
      </div>
    </section>

    <footer class="proof-footer">
      <div class="updated-banner">
        <span class="updated-label">Last observed</span>
        <div class="updated-dates">
          {snapshotObservedAt && <span>{snapshotMeta.snapshotLabel}: {snapshotObservedAt}</span>}
          {factsObservedAt && <span>GitHub facts: {factsObservedAt}</span>}
        </div>
      </div>
      {snapshot && <p class="lock-hash">{snapshotMeta.lockLabel}: {snapshot.lockSha256?.slice(0, 12)}</p>}
    </footer>
  </div>

  <script>
    import { trackEvent } from "../../lib/tracker";

    const slug = window.location.pathname.split("/proof/")[1]?.replace(/\/$/, "") || "";

    document.getElementById("copy-proof-bullets")?.addEventListener("click", async function () {
      const items = document.querySelectorAll("#proof-bullets-list li");
      const text = Array.from(items).map((item) => `- ${item.textContent}`).join("\n");
      try {
        await navigator.clipboard.writeText(text);
        trackEvent("copy_proof_bullets", { slug });
        this.textContent = "Copied";
        setTimeout(() => { this.textContent = "Copy all"; }, 1500);
      } catch {
        this.textContent = "Failed";
        setTimeout(() => { this.textContent = "Copy all"; }, 1500);
      }
    });

    let claimIndex = 0;
    document.querySelectorAll(".claim-copy-btn").forEach((button) => {
      const currentIndex = claimIndex++;
      button.addEventListener("click", async function () {
        const text = this.getAttribute("data-claim-text") || "";
        try {
          await navigator.clipboard.writeText(text);
          trackEvent("copy_claim", { slug, claimIndex: currentIndex });
          this.textContent = "Copied";
          setTimeout(() => { this.textContent = "Copy"; }, 1500);
        } catch {
          this.textContent = "Failed";
          setTimeout(() => { this.textContent = "Copy"; }, 1500);
        }
      });
    });
  </script>
</Base>

<style>
  .proof-page {
    display: grid;
    gap: 1.5rem;
  }

  .back-link {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .proof-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.6fr);
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      var(--color-surface);
  }

  .proof-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4vw, 4rem);
    letter-spacing: -0.05em;
  }

  .one-liner {
    margin-top: 0.8rem;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .badges,
  .claim-evidence {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .proof-hero__meta {
    display: grid;
    gap: 0.75rem;
  }

  .claim-top-row {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .claim-copy-btn,
  .copy-btn {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-text-muted);
    min-height: 2.2rem;
    padding: 0 0.9rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .claim-statement {
    color: var(--color-text);
    font-size: 0.98rem;
    line-height: 1.65;
  }

  .claim-notes,
  .observed,
  .updated-dates,
  .lock-hash {
    color: var(--color-text-dim);
  }

  .bullets-container {
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
  }

  #proof-bullets-list {
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  .clearance-score,
  .updated-label {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .updated-banner {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .updated-dates {
    display: grid;
    gap: 0.2rem;
  }

  @media (max-width: 900px) {
    .proof-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
