---
import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import { kit } from "../../lib/kit";
import overrides from "../../data/overrides.json";
import { getProofData, getToolBySlug } from "../../lib/marketir/loader.mjs";
import { withBase } from "../../lib/site-paths";

const overrideMap = overrides as Record<string, any>;

const proofTools = Object.keys(overrideMap)
  .filter((slug) => overrideMap[slug]?.publicProof === true)
  .map((slug) => {
    const tool = getToolBySlug(slug);
    if (!tool) return null;
    const proof = getProofData(slug);
    return {
      slug,
      name: tool.name,
      oneLiner: tool.positioning?.oneLiner || "",
      stability: overrideMap[slug]?.stability,
      kind: overrideMap[slug]?.kind,
      provenCount: proof?.proven?.length || 0,
      aspirationalCount: proof?.aspirational?.length || 0,
      antiClaimCount: proof?.antiClaims?.length || 0,
    };
  })
  .filter(Boolean);
---

<Base title={`Proof - ${kit.site.title || "DemumuMind"}`} description={`Verified claims, evidence chains, and transparency data for ${kit.site.title || "DemumuMind"} projects.`} currentPath="/proof/">
  <div class="proof-index">
    <PageHero
      eyebrow="Proof directory"
      title="Every claim should leave a trail."
      lede="Browse tool dossiers with proven claims, anti-claims, aspirational statements, and the evidence links behind them."
      meta={[`${proofTools.length} proof pages`, "Machine-readable references", "Trust over hype"]}
    />

    {proofTools.length === 0 ? (
      <div class="empty-state">
        <p>No tools with proof data are available yet.</p>
      </div>
    ) : (
      <div class="tools-grid">
        {proofTools.map((tool) => (
          <a href={withBase(`/proof/${tool.slug}/`)} class="tool-card">
            <div class="card-header">
              <h2>{tool.name}</h2>
              <div class="badges">
                {tool.stability && <span class={`badge badge-${tool.stability}`}>{tool.stability}</span>}
                {tool.kind && <span class="badge badge-kind">{tool.kind}</span>}
              </div>
            </div>
            <p class="one-liner">{tool.oneLiner}</p>
            <div class="card-meta">
              {tool.provenCount > 0 && <span>{tool.provenCount} proven</span>}
              {tool.aspirationalCount > 0 && <span>{tool.aspirationalCount} aspirational</span>}
              {tool.antiClaimCount > 0 && <span>{tool.antiClaimCount} anti-claims</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .proof-index {
    display: grid;
    gap: 1.5rem;
  }

  .card-header,
  .badges {
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .one-liner {
    color: var(--color-text-muted);
  }
</style>
