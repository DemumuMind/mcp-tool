---
import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import overrides from "../../data/overrides.json";
import { getProofData, getToolBySlug } from "../../lib/marketir/loader.mjs";
import { withBase } from "../../lib/site-paths";

const overrideMap = overrides as Record<string, any>;

const proofTools = Object.keys(overrideMap)
  .filter((slug) => overrideMap[slug]?.publicProof === true)
  .map((slug) => {
    const tool = getToolBySlug(slug);
    if (!tool) return null;
    const proof = getProofData(slug);
    return {
      slug,
      name: tool.name,
      oneLiner: tool.positioning?.oneLiner || "",
      stability: overrideMap[slug]?.stability,
      kind: overrideMap[slug]?.kind,
      provenCount: proof?.proven?.length || 0,
      aspirationalCount: proof?.aspirational?.length || 0,
      antiClaimCount: proof?.antiClaims?.length || 0,
    };
  })
  .filter(Boolean);
---

<Base
  title="Proof Reference - DemumuMind MCP"
  description="Secondary evidence reference for MCP listings in the marketplace."
  currentPath="/proof/"
>
  <div class="page-content proof-index">
    <PageHero
      eyebrow="Proof reference"
      title="Evidence pages for marketplace listings."
      lede="Use proof pages after browse, categories, platform hubs, or tool pages when you need claim-level support, caveats, and source links."
      meta={[`${proofTools.length} proof references`, "Evidence-linked", "Marketplace-linked"]}
      asideTitle="Start elsewhere first"
      asideBody="Primary discovery should begin in the marketplace. Proof pages are for validation, not first-pass browsing."
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Open stats</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
      </Fragment>
    </PageHero>

    {proofTools.length === 0 ? (
      <div class="empty-state">
        <p>No tools with public proof references are available yet.</p>
      </div>
    ) : (
      <div class="tools-grid">
        {proofTools.map((tool) => (
          <a href={withBase(`/proof/${tool.slug}/`)} class="tool-card">
            <div class="card-header">
              <h2>{tool.name}</h2>
              <div class="badges">
                {tool.stability && <span class={`badge badge-${tool.stability}`}>{tool.stability}</span>}
                {tool.kind && <span class="badge badge-kind">{tool.kind}</span>}
              </div>
            </div>
            <p class="one-liner">
              {tool.oneLiner || "Evidence-backed claims, limits, and supporting links for this listing."}
            </p>
            <div class="card-meta">
              {tool.provenCount > 0 && <span>{tool.provenCount} supported</span>}
              {tool.aspirationalCount > 0 && <span>{tool.aspirationalCount} open claims</span>}
              {tool.antiClaimCount > 0 && <span>{tool.antiClaimCount} limits</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .proof-index {
    display: grid;
    gap: 1.5rem;
  }

  .card-header,
  .badges {
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .one-liner {
    color: var(--color-text-muted);
  }
</style>
