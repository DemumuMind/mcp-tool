---
import PageHero from "../components/PageHero.astro";
import Base from "../layouts/Base.astro";
import stats from "../data/org-stats.json";
import cleanup from "../data/registry/cleanup.json";

const health = (stats as any).registryHealth || {};
const cleanupData = cleanup as any;
---

<Base title="Registry - DemumuMind" description="The DemumuMind registry: what it is, what listing means, and how to add a tool." currentPath="/registry/">
  <div class="page-content">
    <PageHero
      eyebrow="Registry contract"
      title="The canonical metadata layer."
      lede="Registry entries are the reviewed install and naming contract for discoverable tools. Org-only repos exist upstream, but they have not cleared the listing workflow yet."
      meta={[
        `${health.registryToolCount || 0} registry tools`,
        `${health.orgOnlyRepos || 0} org-only repos`,
        `${cleanupData.totalIssues || 0} cleanup issues`,
      ]}
    />

    <h2>What registry-listed means</h2>
    <ul>
      <li>The tool has been reviewed and added to <code>registry.json</code>.</li>
      <li>Its name, description, tags, and install contract are curated.</li>
      <li>Clients such as <a href="/tools/tool-compass/">Tool Compass</a> can discover it reliably.</li>
    </ul>

    <h2>How to add a tool</h2>
    <ol>
      <li>Push the repo into the DemumuMind organization.</li>
      <li>Open a PR against <a href="https://github.com/DemumuMind/mcp-tool-registry" rel="noopener">mcp-tool-registry</a>.</li>
      <li>Include the canonical metadata: ID, name, description, repo URL, install object, and tags.</li>
      <li>After merge, the next sync makes the listing visible here.</li>
    </ol>

    <h2>Registry health</h2>
    <div class="health-grid">
      <div class="health-item">
        <span class="health-value">{health.registryToolCount || 0}</span>
        <span class="health-label">Registry tools</span>
      </div>
      <div class="health-item">
        <span class="health-value">{health.registeredInProjects || 0}</span>
        <span class="health-label">Active projects</span>
      </div>
      <div class="health-item">
        <span class="health-value">{health.orgOnlyRepos || 0}</span>
        <span class="health-label">Org-only repos</span>
      </div>
      <div class="health-item">
        <span class="health-value">{health.registryArchived || health.registryNoRepo || 0}</span>
        <span class="health-label">Archived or missing</span>
      </div>
    </div>

    {cleanupData.archived?.length > 0 && (
      <>
        <h2>Archived repos</h2>
        <ul class="cleanup-list">
          {cleanupData.archived.map((item: any) => (
            <li>
              <code>{item.registryId}</code>
              <span>{item.repoName}</span>
              <span class="cleanup-action">{item.action}</span>
            </li>
          ))}
        </ul>
      </>
    )}

    {cleanupData.aliases?.length > 0 && (
      <>
        <h2>Active aliases</h2>
        <ul class="cleanup-list">
          {cleanupData.aliases.map((item: any) => (
            <li>
              <code>{item.registryId}</code>
              <span>{item.repoName}</span>
              <span class="cleanup-action">{item.reason}</span>
            </li>
          ))}
        </ul>
      </>
    )}
  </div>
</Base>

<style>
  .cleanup-list {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cleanup-list li {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text-muted);
  }

  .cleanup-action {
    color: var(--color-text-dim);
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
