---
import Base from "../layouts/Base.astro";
import MarketplaceCard from "../components/MarketplaceCard.astro";
import { getMarketplaceContent } from "../lib/content/marketplace.ts";
import { withBase } from "../lib/site-paths";

const content = getMarketplaceContent();
const formatNumber = (value: number) => new Intl.NumberFormat("en-US").format(value);
const heroSuggestions = [
  ...content.catalog.primary.slice(0, 10).map((entry) => entry.name),
  ...content.categories.slice(0, 6).map((category) => category.title),
  ...content.docs.slice(0, 4).map((doc) => doc.title),
];
---

<Base
  title="DemumuMind MCP"
  description="Find MCP tools, compare your options, and review compatibility and quality signals in one place."
  currentPath="/"
>
  <div class="home-flow">
    <section class="marketplace-hero">
      <div class="marketplace-hero__copy">
        <p class="eyebrow">DemumuMind MCP tool shop</p>
        <h1 class="marketplace-hero__title">Find MCP tools that fit your stack.</h1>
        <p class="marketplace-hero__lede">
          Search a curated marketplace of MCP servers, apps, and utilities with clearer compatibility notes, quality signals, and comparison pages for faster decisions.
        </p>

        <form class="search-omnibox" id="home-search-form" action={withBase("/tools/")}>
          <label class="sr-only" for="home-search">Search MCP tools</label>
          <input
            id="home-search"
            name="q"
            list="home-search-suggestions"
            placeholder="Search MCP tools, categories, docs, or platforms"
            autocomplete="off"
          />
          <button type="submit" class="btn btn-primary">Explore tools</button>
        </form>
        <datalist id="home-search-suggestions">
          {heroSuggestions.map((item) => <option value={item} />)}
        </datalist>

        <div class="marketplace-hero__quickfacets">
          {content.categories.slice(0, 5).map((category) => (
            <a href={withBase(`/tools/?category=${category.slug}`)} class="compat-pill">{category.title}</a>
          ))}
        </div>
      </div>

      <div class="marketplace-hero__aside">
        <div class="metric-card">
          <span class="metric-card__label">Listed tools</span>
          <strong class="metric-card__value">{formatNumber(content.stats.totalListings)}</strong>
          <p>Public MCP tools and apps you can browse right now.</p>
        </div>
        <div class="metric-card">
          <span class="metric-card__label">Verified tools</span>
          <strong class="metric-card__value">{formatNumber(content.stats.verifiedListings)}</strong>
          <p>Listings with clearer docs, fresher releases, and stronger public signals.</p>
        </div>
        <div class="metric-card">
          <span class="metric-card__label">Browse paths</span>
          <strong class="metric-card__value">{formatNumber(content.categories.length)}</strong>
          <p>Category hubs that help you narrow the catalog by workflow.</p>
        </div>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Featured</p>
          <h2 class="section-shell__title">Strong places to start</h2>
        </div>
        <a href={withBase("/tools/")} class="see-all">Browse all</a>
      </div>
      <div class="featured-tools-grid">
        {content.catalog.featured.map((entry) => <MarketplaceCard entry={entry} compact />)}
      </div>
    </section>

    <section class="section-split">
      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Trending</p>
            <h2 class="section-shell__title">Tools getting attention</h2>
          </div>
        </div>
        <div class="featured-tools-grid">
          {content.catalog.trending.slice(0, 4).map((entry) => <MarketplaceCard entry={entry} compact />)}
        </div>
      </div>

      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">New</p>
            <h2 class="section-shell__title">Recently updated</h2>
          </div>
        </div>
        <div class="featured-tools-grid">
          {content.catalog.newest.slice(0, 4).map((entry) => <MarketplaceCard entry={entry} compact />)}
        </div>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Categories</p>
          <h2 class="section-shell__title">Browse by category</h2>
        </div>
        <a href={withBase("/categories/")} class="see-all">All categories</a>
      </div>
      <div class="platform-hub-grid">
        {content.categories.slice(0, 6).map((category) => (
          <a href={withBase(`/categories/${category.slug}/`)} class="collection-item">
            <span class="collection-item-name">{category.title}</span>
            <span class="collection-item-desc">{category.description}</span>
            <span class="collection-item-count">{formatNumber(category.count)} listed tools</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Platform hubs</p>
          <h2 class="section-shell__title">Browse by client or runtime</h2>
        </div>
        <a href={withBase("/platforms/")} class="see-all">All platforms</a>
      </div>
      <div class="platform-hub-grid">
        {content.platforms.slice(0, 6).map((platform) => (
          <a href={withBase(`/platforms/${platform.slug}/`)} class="collection-item">
            <span class="collection-item-name">{platform.title}</span>
            <span class="collection-item-desc">{platform.description}</span>
            <span class="collection-item-count">{formatNumber(platform.count)} matching tools</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Collections</p>
          <h2 class="section-shell__title">Hand-picked tool sets</h2>
        </div>
        <a href={withBase("/collections/")} class="see-all">All collections</a>
      </div>
      <div class="platform-hub-grid">
        {content.collections.slice(0, 4).map((collection) => (
          <a href={withBase(`/collections/${collection.slug}/`)} class="collection-item">
            <span class="collection-item-name">{collection.title}</span>
            <span class="collection-item-desc">{collection.description}</span>
            <span class="collection-item-count">{formatNumber(collection.count)} tools in set</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-split">
      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Docs</p>
            <h2 class="section-shell__title">How to use the catalog well</h2>
          </div>
          <a href={withBase("/docs/")} class="see-all">Docs hub</a>
        </div>
        <div class="featured-tools-grid">
          {content.docs.slice(0, 3).map((doc) => (
            <a href={withBase(`/docs/${doc.slug}/`)} class="collection-item">
              <span class="collection-item-name">{doc.title}</span>
              <span class="collection-item-desc">{doc.summary}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">FAQ</p>
            <h2 class="section-shell__title">Common questions</h2>
          </div>
          <a href={withBase("/faq/")} class="see-all">Open FAQ</a>
        </div>
        <div class="faq-preview-grid">
          {content.faq.slice(0, 4).map((item) => (
            <article class="collection-item">
              <span class="collection-item-name">{item.question}</span>
              <span class="collection-item-desc">{item.answer}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Stats</p>
          <h2 class="section-shell__title">Catalog health at a glance</h2>
        </div>
        <a href={withBase("/stats/")} class="see-all">Open stats</a>
      </div>
      <div class="stats-grid">
        <div class="metric-card">
          <span class="metric-card__label">Average score</span>
          <strong class="metric-card__value">{formatNumber(content.stats.averageScore)}</strong>
          <p>Average marketplace score across documentation, freshness, adoption, and trust cues.</p>
        </div>
        <div class="metric-card">
          <span class="metric-card__label">Open-source tools</span>
          <strong class="metric-card__value">{formatNumber(content.stats.openSourceListings)}</strong>
          <p>Listings backed by public repositories and visible development history.</p>
        </div>
        <div class="metric-card">
          <span class="metric-card__label">Commercial tools</span>
          <strong class="metric-card__value">{formatNumber(content.stats.commercialListings)}</strong>
          <p>Listings sourced from official product pages and vendor documentation.</p>
        </div>
      </div>
    </section>
  </div>
</Base>
