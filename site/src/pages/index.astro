---
import PageHero from "../components/PageHero.astro";
import Base from "../layouts/Base.astro";
import projects from "../data/projects.json";
import collections from "../data/collections.json";
import releases from "../data/releases.json";
import stats from "../data/org-stats.json";
import todaysPicks from "../data/todays-picks.json";

const projectsByRepo = new Map((projects as any[]).map((project: any) => [project.repo, project]));
const featuredProjects = (projects as any[]).filter((project: any) => project.featured);
const recentReleases = (releases as any[]).slice(0, 5);
const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000);
const spotlightIndex = featuredProjects.length > 0 ? dayOfYear % featuredProjects.length : 0;
const spotlight = featuredProjects[spotlightIndex];
const gridProjects = todaysPicks.picks.map((pick) => projectsByRepo.get(pick.slug)).filter(Boolean);

function relativeDate(iso: string) {
  if (!iso) return "";
  const diff = Date.now() - new Date(iso).getTime();
  const days = Math.floor(diff / 86400000);
  if (days === 0) return "today";
  if (days === 1) return "yesterday";
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  return months === 1 ? "1mo ago" : `${months}mo ago`;
}

const releaseHeading = recentReleases.length > 0 ? "Recent release chronicle" : "Release chronicle";
---

<Base title="DemumuMind" currentPath="/">
  <PageHero
    eyebrow="Protocol Editorial / Dark Trust Infrastructure"
    title="A trust-first index for serious agent tools."
    lede="Curated MCP servers, desktop apps, proofs, receipts, and release evidence for local-first operator workflows."
    align="center"
    meta={[
      `${stats.repoCount} public repos`,
      "100% local-first posture",
      "MCP-native surfaces",
    ]}
  >
    <Fragment slot="actions">
      <a href="/tools/" class="btn btn-primary">Browse tools</a>
      <a href="/trust/" class="btn btn-secondary">See trust model</a>
    </Fragment>
  </PageHero>

  {spotlight && (
    <section class="spotlight-section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Featured surface</p>
          <h2 class="section-shell__title">Today&apos;s operator focus</h2>
        </div>
        <a href={`/tools/${spotlight.repo}/`} class="see-all">Open dossier</a>
      </div>

      <article class="spotlight-card">
        <div class="spotlight-card__copy">
          <span class="spotlight-card__label">Registry spotlight</span>
          <h3><a href={`/tools/${spotlight.repo}/`}>{spotlight.name}</a></h3>
          <p>{spotlight.description || spotlight.tagline}</p>
          <div class="spotlight-card__meta">
            {spotlight.language && <span>{spotlight.language}</span>}
            {spotlight.stars > 0 && <span>{spotlight.stars} stars</span>}
            {spotlight.kind && <span>{spotlight.kind}</span>}
          </div>
        </div>
        <div class="spotlight-card__media">
          <img
            src={`/screenshots/${spotlight.repo}.png`}
            alt={`Screenshot of ${spotlight.name}`}
            width="880"
            height="540"
            loading="eager"
            onerror="this.closest('.spotlight-card__media').style.display='none'"
          />
        </div>
      </article>
    </section>
  )}

  <section class="section-shell">
    <div class="section-shell__header">
      <div>
        <p class="section-kicker">Release cadence</p>
        <h2 class="section-shell__title">{releaseHeading}</h2>
      </div>
      <a href="/releases/" class="see-all">All releases</a>
    </div>
    <div class="release-strip">
      {recentReleases.map((release: any) => (
        <a href={`/tools/${release.repo}/`} class="release-chip">
          <span class="release-chip-name">{release.toolName}</span>
          <span class="release-chip-tag">{release.tag}</span>
          <span class="release-chip-date">{relativeDate(release.publishedAt)}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section-shell">
    <div class="section-shell__header">
      <div>
        <p class="section-kicker">Curated picks</p>
        <h2 class="section-shell__title">Tools worth opening first</h2>
      </div>
    </div>
    <div class="project-grid">
      {gridProjects.map((project: any) => (
        <article class="project-card">
          <div class="card-header-home">
            <h3><a href={`/tools/${project.repo}/`}>{project.name}</a></h3>
            <div class="card-badges">
              {project.stability && <span class={`badge badge-${project.stability}`}>{project.stability}</span>}
              {project.kind && <span class="badge badge-kind">{project.kind}</span>}
            </div>
          </div>
          <p>{project.tagline || project.description}</p>
          {project.install && <code class="install-line">{project.install}</code>}
          <div class="card-meta">
            {project.stars > 0 && <span class="meta-item">{project.stars} stars</span>}
            {project.language && <span class="meta-item">{project.language}</span>}
          </div>
        </article>
      ))}
    </div>
  </section>

  {(collections as any[]).map((collection: any) => {
    const items = collection.repos.map((repo: string) => projectsByRepo.get(repo)).filter(Boolean);
    if (items.length === 0) return null;

    return (
      <section class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Curated stack</p>
            <h2 class="section-shell__title">{collection.title}</h2>
          </div>
        </div>
        <p class="section-subheading">{collection.description}</p>
        <div class="collection-grid">
          {items.map((project: any) => (
            <a href={`/tools/${project.repo}/`} class="collection-item">
              <span class="collection-item-name">{project.name}</span>
              <span class="collection-item-desc">{project.tagline || project.description}</span>
            </a>
          ))}
        </div>
      </section>
    );
  })}
</Base>

<style>
  .spotlight-section {
    margin-top: 2rem;
  }

  .spotlight-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: 1.25rem;
    padding: 1.1rem;
  }

  .spotlight-card__copy {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 0.65rem;
  }

  .spotlight-card__label {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .spotlight-card__copy h3 {
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 3vw, 3rem);
    letter-spacing: -0.05em;
  }

  .spotlight-card__copy p {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .spotlight-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .spotlight-card__meta span {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.16rem 0.65rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .spotlight-card__media {
    min-height: 320px;
    overflow: hidden;
    border-radius: calc(var(--radius) - 2px);
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .spotlight-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .release-strip {
    flex-direction: row;
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }

  .release-chip {
    min-width: 240px;
    text-decoration: none;
  }

  .release-chip-name {
    color: var(--color-text);
    font-weight: 600;
  }

  .install-line {
    overflow-x: auto;
    white-space: nowrap;
  }

  .card-header-home,
  .card-badges {
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .spotlight-card {
      grid-template-columns: 1fr;
    }
  }
</style>
