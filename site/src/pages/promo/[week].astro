---
export const prerender = true;

import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import ProofBadge from "../../components/ProofBadge.astro";
import { kit } from "../../lib/kit";
import fs from "node:fs";
import path from "node:path";
import { withBase } from "../../lib/site-paths";

export function getStaticPaths() {
  const outreachDir = path.join(process.cwd(), "public/outreach-run");
  const paths = [];

  try {
    if (!fs.existsSync(outreachDir)) return paths;

    const entries = fs.readdirSync(outreachDir, { withFileTypes: true });
    for (const entry of entries) {
      if (!entry.isDirectory()) continue;
      if (!/^\d{4}-\d{2}-\d{2}$/.test(entry.name)) continue;

      const runPath = path.join(outreachDir, entry.name, "outreach-run.json");
      try {
        if (fs.existsSync(runPath)) {
          const data = JSON.parse(fs.readFileSync(runPath, "utf8"));
          paths.push({
            params: { week: entry.name },
            props: { outreachRun: data },
          });
        }
      } catch {}
    }
  } catch {}

  return paths;
}

const { week } = Astro.params;
const { outreachRun } = Astro.props;

let overrides = {};
try {
  const overridesPath = path.join(process.cwd(), "src/data/overrides.json");
  if (fs.existsSync(overridesPath)) {
    overrides = JSON.parse(fs.readFileSync(overridesPath, "utf8"));
  }
} catch {}

const items = outreachRun?.items || [];
const promotionType = outreachRun?.promotionType || "own";
const generatedAt = outreachRun?.generatedAt
  ? new Date(outreachRun.generatedAt).toISOString().slice(0, 10)
  : null;

let receipt = null;
try {
  const receiptPath = path.join(process.cwd(), "public/outreach-run", week, "promo-week-receipt.json");
  if (fs.existsSync(receiptPath)) {
    receipt = JSON.parse(fs.readFileSync(receiptPath, "utf8"));
  }
} catch {}

let trust = null;
try {
  const trustPath = path.join(process.cwd(), "public/trust.json");
  if (fs.existsSync(trustPath)) {
    trust = JSON.parse(fs.readFileSync(trustPath, "utf8"));
  }
} catch {}

const repoMarketing = kit.repo.marketing || "DemumuMind/mcp-tool";
const commitSha = trust?.commit || null;
const hasVerifyData = receipt && (receipt.inputs || receipt.trustReceiptHash);

const verifyInputs = [];
if (receipt?.inputs) {
  if (receipt.inputs.promoDecisionsSha) {
    verifyInputs.push({ path: "site/src/data/promo-decisions.json", sha256: receipt.inputs.promoDecisionsSha });
  }
  if (receipt.inputs.experimentDecisionsSha) {
    verifyInputs.push({ path: "site/src/data/experiment-decisions.json", sha256: receipt.inputs.experimentDecisionsSha });
  }
  if (receipt.inputs.governanceSha) {
    verifyInputs.push({ path: "site/src/data/governance.json", sha256: receipt.inputs.governanceSha });
  }
}

function resolveHref(href?: string | null) {
  if (!href) return null;
  return href.startsWith("/") ? withBase(href) : href;
}

const title = `Promotion Reference: ${week}`;
const description = `Secondary promotion reference for marketplace week ${week}.`;
---

<Base title={title} description={description} currentPath={`/promo/${week}/`}>
  <div class="page-content promo-week-page" data-telemetry-week={week} data-repo-marketing={repoMarketing}>
    <div class="breadcrumbs">
      <a href={withBase("/receipts/")}>Receipts</a>
      <span>/</span>
      <span>{week}</span>
    </div>

    <PageHero
      eyebrow="Reference surface"
      title={`Promotion reference for ${week}`}
      lede="This week-level record shows which listings entered outbound promotion and which inputs were hashed. Use it as an audit trail after you evaluate tools in the marketplace."
      meta={[
        `${items.length} ${items.length === 1 ? "listing" : "listings"}`,
        `${promotionType} run`,
        generatedAt ? `Generated ${generatedAt}` : "Generated on demand",
      ]}
      asideTitle="Promotion is not ranking"
      asideBody="Inclusion here is a secondary operational signal. Ranking, verification, and shortlist decisions should still come from browse, methodology, stats, and tool dossiers."
    >
      <Fragment slot="actions">
        <a href={withBase("/receipts/")} class="btn btn-secondary">All receipts</a>
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Run contents</p>
          <h2 class="section-shell__title">Included listings</h2>
        </div>
      </div>
      {items.length === 0 ? (
        <div class="empty-state">
          <p>No listings were recorded for this promotion week.</p>
        </div>
      ) : (
        <div class="weeks-list">
          {items.map((item, index) => {
            const override = overrides[item.slug] || {};
            const links = item.links || {};
            const proofHref = resolveHref(links.proof || `/proof/${item.slug}/`);
            const pressHref = resolveHref(links.presskit);
            const snippetsHref = resolveHref(links.snippets);

            return (
              <article class="week-card">
                <div class="week-header">
                  <span class="week-date">{String(index + 1).padStart(2, "0")}</span>
                  <div class="week-header__copy">
                    <h3>{item.slug}</h3>
                    {override.tagline && <p class="section-subheading">{override.tagline}</p>}
                  </div>
                  <div class="week-badges">
                    <span class={`badge badge-${promotionType === "own" ? "registered" : promotionType === "partner" ? "beta" : "experimental"}`}>{promotionType}</span>
                    {receipt && <ProofBadge type="receipt" />}
                  </div>
                </div>
                <div class="button-row">
                  <a href={withBase(`/tools/${item.slug}/`)} class="btn btn-secondary">Tool dossier</a>
                  {proofHref && <a href={proofHref} class="btn btn-secondary">Proof reference</a>}
                  {pressHref && <a href={pressHref} class="btn btn-secondary">Press reference</a>}
                  {snippetsHref && <a href={snippetsHref} class="btn btn-secondary">Messaging snippets</a>}
                  <button
                    class="btn btn-secondary copy-btn"
                    data-url={proofHref || withBase(`/proof/${item.slug}/`)}
                    title="Copy proof link"
                  >
                    Copy proof link
                  </button>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </section>

    {hasVerifyData && (
      <section class="section-shell" id="audit">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Audit bundle</p>
            <h2 class="section-shell__title">Verification inputs</h2>
          </div>
        </div>
        <div class="verify-recipe">
          <div class="week-links">
            <span><strong>Week:</strong> {week}</span>
            {commitSha && commitSha !== "unknown" && (
              <span>
                <strong>Commit:</strong>{" "}
                <a href={`https://github.com/${repoMarketing}/commit/${commitSha}`} rel="noopener">
                  <code>{commitSha.slice(0, 8)}</code>
                </a>
              </span>
            )}
          </div>

          {verifyInputs.length > 0 && (
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Input file</th>
                    <th>SHA-256</th>
                  </tr>
                </thead>
                <tbody>
                  {verifyInputs.map((input) => (
                    <tr>
                      <td class="mono">{input.path}</td>
                      <td class="mono">{input.sha256.replace(/^sha256:/, "").slice(0, 16)}...</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          <div class="button-row">
            <button
              class="btn btn-primary"
              id="copy-bundle-btn"
              data-week={week}
              data-generated={receipt?.generatedAt || ""}
              data-commit={commitSha || ""}
              data-inputs={JSON.stringify(verifyInputs)}
              data-receipt-hash={receipt?.trustReceiptHash || ""}
            >
              Copy audit bundle
            </button>
            <button
              class="btn btn-secondary"
              id="copy-verify-cmd-btn"
              data-commit={commitSha || ""}
              data-files={verifyInputs.map((input) => input.path).join(" ")}
            >
              Copy verification command
            </button>
          </div>
        </div>
      </section>
    )}

    {receipt && (
      <section class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Recorded hashes</p>
            <h2 class="section-shell__title">Receipt notes</h2>
          </div>
        </div>
        <div class="steps-box">
          <ul>
            {receipt.inputs?.promoDecisionsSha && <li>Promo decisions: <code>{receipt.inputs.promoDecisionsSha.slice(0, 20)}...</code></li>}
            {receipt.inputs?.governanceSha && <li>Governance: <code>{receipt.inputs.governanceSha.slice(0, 20)}...</code></li>}
            {receipt.trustReceiptHash && <li>Trust receipt: <code>{receipt.trustReceiptHash.slice(0, 20)}...</code></li>}
          </ul>
        </div>
      </section>
    )}
  </div>
</Base>

<script>
  import { trackEvent } from "../../lib/tracker";

  document.addEventListener("DOMContentLoaded", () => {
    const week = document.querySelector("[data-telemetry-week]")?.getAttribute("data-telemetry-week") || "";

    document.querySelectorAll(".copy-btn").forEach((button) => {
      button.addEventListener("click", async () => {
        const url = button.dataset.url;
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);
          const slug = url.split("/proof/")[1]?.replace(/\/$/, "") || "";
          trackEvent("copy_proof_link", { week, slug });
          const original = button.textContent;
          button.textContent = "Copied!";
          setTimeout(() => { button.textContent = original; }, 2000);
        } catch {}
      });
    });

    const bundleButton = document.getElementById("copy-bundle-btn");
    if (bundleButton) {
      bundleButton.addEventListener("click", async () => {
        const dataset = bundleButton.dataset;
        let inputs = [];
        try {
          inputs = JSON.parse(dataset.inputs || "[]");
        } catch {}

        const bundle = {
          week: dataset.week,
          generatedAt: dataset.generated,
          commit: dataset.commit,
          hashAlg: "sha256",
          inputs,
          trustReceiptHash: dataset.receiptHash || null,
          notes: [
            "Inputs hashed exactly as read by gen-promo-week-receipt.mjs",
            "If decisionsFrozen=true, promos unchanged from prior frozen state",
          ],
        };

        try {
          await navigator.clipboard.writeText(JSON.stringify(bundle, null, 2));
          trackEvent("copy_bundle", { week });
          const original = bundleButton.textContent;
          bundleButton.textContent = "Copied!";
          setTimeout(() => { bundleButton.textContent = original; }, 2000);
        } catch {}
      });
    }

    const verifyCommandButton = document.getElementById("copy-verify-cmd-btn");
    if (verifyCommandButton) {
      verifyCommandButton.addEventListener("click", async () => {
        const dataset = verifyCommandButton.dataset;
        const commit = dataset.commit || "<COMMIT_SHA>";
        const files = dataset.files || "";
        const marketingRepo = document.querySelector("[data-repo-marketing]")?.getAttribute("data-repo-marketing") || "DemumuMind/mcp-tool";
        const repositoryName = marketingRepo.split("/").pop();
        const command = [
          `git clone https://github.com/${marketingRepo}.git && cd ${repositoryName}`,
          `git checkout ${commit}`,
          `sha256sum ${files}`,
          "# Compare output to bundle hashes",
        ].join("\n");

        try {
          await navigator.clipboard.writeText(command);
          trackEvent("copy_verify_cmd", { week });
          const original = verifyCommandButton.textContent;
          verifyCommandButton.textContent = "Copied!";
          setTimeout(() => { verifyCommandButton.textContent = original; }, 2000);
        } catch {}
      });
    }
  });
</script>

<style>
  .promo-week-page {
    display: grid;
    gap: 1.5rem;
  }

  .week-header {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .week-header__copy {
    display: grid;
    gap: 0.35rem;
    flex: 1;
    min-width: 0;
  }

  .week-header__copy h3 {
    font-size: 1rem;
  }

  .week-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
