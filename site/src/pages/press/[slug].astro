---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import overrides from "../../data/overrides.json";
import fs from "node:fs";
import path from "node:path";
import {
  getPressData,
  getProofData,
  getPublicAssetLinks,
  getSnapshotMeta,
  getToolBySlug,
  loadSnapshot,
} from "../../lib/marketir/loader.mjs";
import { withBase } from "../../lib/site-paths";

const overrideMap = overrides as Record<string, any>;

export function getStaticPaths() {
  const overridesBySlug = overrides as Record<string, any>;
  return Object.keys(overridesBySlug)
    .filter((slug) => overridesBySlug[slug]?.publicProof === true)
    .map((slug) => ({
      slug,
      tool: getToolBySlug(slug),
    }))
    .filter(({ tool }) => tool)
    .map(({ slug, tool }) => ({
      params: { slug },
      props: { slug, tool },
    }));
}

const { slug, tool } = Astro.props;
const override = overrideMap[slug] || {};
const press = getPressData(slug) || tool.press;
const proofData = getProofData(slug);
const snapshot = loadSnapshot();
const snapshotMeta = getSnapshotMeta(snapshot);
const publicAssetLinks = getPublicAssetLinks(slug);

let facts: any = null;
try {
  const factsPath = path.join(process.cwd(), "src/data/github-facts", `${slug}.json`);
  facts = JSON.parse(fs.readFileSync(factsPath, "utf8"));
} catch {}

const orgUrl = `https://github.com/DemumuMind/${slug}`;
const pressKitLink = publicAssetLinks.find((link) => link.kind === "presskit");
const supportedClaimCount = proofData?.proven?.length || 0;
const quoteCount = press?.quotes?.length || 0;
const assetCount = publicAssetLinks.length;
const snapshotObservedAt = snapshot?.fetchedAt
  ? new Date(snapshot.fetchedAt).toLocaleDateString("en-US", { dateStyle: "medium" })
  : null;
---

<Base
  title={`${tool.name} Press Reference - DemumuMind MCP`}
  description={press?.boilerplate?.projectDescription || tool.positioning?.oneLiner || ""}
  currentPath={`/press/${slug}/`}
>
  <div class="page-content press-page">
    <a href={withBase("/press/")} class="back-link">&larr; All press references</a>

    <PageHero
      eyebrow="Reference surface"
      title={`${tool.name} press reference`}
      lede="This page is a secondary briefing surface for editors, partners, and operators who already evaluated the listing in the marketplace. Start with the tool dossier, then use this page for narrative context, approved quotes, and reusable assets."
      meta={[
        supportedClaimCount > 0 ? `${supportedClaimCount} supported claims` : "Reference-ready claims",
        quoteCount > 0 ? `${quoteCount} approved quotes` : "No quote bank",
        assetCount > 0 ? `${assetCount} downloadable assets` : "No downloadable assets",
      ]}
      asideTitle="Primary discovery stays in the marketplace"
      asideBody="Use tools, stats, categories, platforms, and methodology as the primary surfaces. This page packages supporting narrative after shortlisting."
    >
      <Fragment slot="actions">
        <a href={withBase(`/tools/${slug}/`)} class="btn btn-primary">Open tool dossier</a>
        <a href={withBase(`/proof/${slug}/`)} class="btn btn-secondary">Open proof reference</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
        {pressKitLink && <a href={pressKitLink.href} class="btn btn-secondary" rel="noopener">Press kit</a>}
      </Fragment>
    </PageHero>

    <section class="section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Reference path</p>
          <h2 class="section-shell__title">Use this page after the dossier</h2>
        </div>
      </div>
      <div class="rule-box">
        <p>Start with the marketplace dossier for positioning, adoption, compatibility, and related alternatives.</p>
        <p>Use proof, stats, and methodology if you need evidence, freshness, or ranking context before reusing any claim from this page.</p>
      </div>
    </section>

    {press?.boilerplate?.projectDescription && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Marketplace summary</p>
            <h2 class="section-shell__title">Project context</h2>
          </div>
        </div>
        <div class="rule-box">
          <p>{press.boilerplate.projectDescription}</p>
          {press.boilerplate.founderBio && <p>{press.boilerplate.founderBio}</p>}
          {press.boilerplate.preferredNouns?.length > 0 && (
            <p>Preferred terms: {press.boilerplate.preferredNouns.join(", ")}</p>
          )}
        </div>
      </section>
    )}

    {proofData?.proven?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Evidence-backed briefing</p>
            <h2 class="section-shell__title">Supported talking points</h2>
          </div>
        </div>
        <div class="claims-list">
          {proofData.proven.map((claim: any) => (
            <article class="claim">
              <div class="claim-statement">{claim.statement}</div>
              {claim.evidence?.length > 0 && (
                <div class="claim-evidence">
                  {claim.evidence.map((evidence: any) => (
                    <span class="tag">
                      {evidence.url ? (
                        <a href={evidence.url} target="_blank" rel="noopener">{evidence.type}: {evidence.id.split(".").pop()}</a>
                      ) : evidence.path ? (
                        <a href={withBase(`/marketir/evidence/${evidence.path.split("/").pop()}`)} target="_blank" rel="noopener">{evidence.type}: {evidence.id.split(".").pop()}</a>
                      ) : (
                        <span>{evidence.type}: {evidence.id.split(".").pop()}</span>
                      )}
                    </span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {press?.quotes?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Approved language</p>
            <h2 class="section-shell__title">Quotes</h2>
          </div>
        </div>
        <div class="quotes-list">
          {press.quotes.map((quote: any) => (
            <blockquote class="quote">
              <p>"{quote.text}"</p>
              {quote.attribution && <cite>- {quote.attribution}{quote.role ? `, ${quote.role}` : ""}</cite>}
            </blockquote>
          ))}
        </div>
      </section>
    )}

    {press?.comparables?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Comparison context</p>
            <h2 class="section-shell__title">How this listing is framed</h2>
          </div>
        </div>
        <div class="comparables-list">
          {press.comparables.map((comparable: any) => (
            <article class="comparable">
              <strong>Similar to {comparable.target}</strong>
              <p>{comparable.distinction}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    {press?.partnerOffers?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Partner notes</p>
            <h2 class="section-shell__title">Reusable offers and constraints</h2>
          </div>
        </div>
        <div class="offers-list">
          {press.partnerOffers.map((offer: any) => (
            <article class="offer">
              <span class="offer-type">{offer.type}</span>
              <p>{offer.description}</p>
              {offer.constraints && <p class="offer-constraints">{offer.constraints}</p>}
            </article>
          ))}
        </div>
      </section>
    )}

    {facts && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Observed repository signals</p>
            <h2 class="section-shell__title">GitHub context</h2>
          </div>
        </div>
        <div class="facts-grid">
          {facts.stars != null && <div class="fact"><span class="fact-value">{facts.stars}</span><span class="fact-label">Stars</span></div>}
          {facts.forks != null && <div class="fact"><span class="fact-value">{facts.forks}</span><span class="fact-label">Forks</span></div>}
          {facts.openIssues != null && <div class="fact"><span class="fact-value">{facts.openIssues}</span><span class="fact-label">Open issues</span></div>}
          {facts.releasesLast90d != null && <div class="fact"><span class="fact-value">{facts.releasesLast90d}</span><span class="fact-label">Releases (90d)</span></div>}
          {facts.latestRelease && <div class="fact"><span class="fact-value">{facts.latestRelease.tag}</span><span class="fact-label">Latest release</span></div>}
          {facts.license && <div class="fact"><span class="fact-value">{facts.license}</span><span class="fact-label">License</span></div>}
        </div>
      </section>
    )}

    {press?.contacts?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Contact points</p>
            <h2 class="section-shell__title">Who to route to</h2>
          </div>
        </div>
        <div class="contacts-list">
          {press.contacts.map((contact: any) => (
            <div class="contact">
              <span class="contact-method">{contact.method}</span>
              {contact.href ? (
                <a href={contact.href} target="_blank" rel="noopener">{contact.label || contact.value}</a>
              ) : (
                <span>{contact.label || contact.value}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Linked surfaces</p>
          <h2 class="section-shell__title">Open reference assets</h2>
        </div>
      </div>
      <div class="downloads">
        <a href={withBase(`/tools/${slug}/`)} class="btn btn-secondary">Tool dossier</a>
        <a href={withBase(`/proof/${slug}/`)} class="btn btn-secondary">Proof reference</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Marketplace stats</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Methodology</a>
        {publicAssetLinks.map((link) => (
          <a href={link.href} class="btn btn-secondary" rel="noopener">{link.label}</a>
        ))}
        <a href={orgUrl} class="btn btn-secondary" rel="noopener">GitHub</a>
      </div>
    </section>

    {override.screenshot && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Reference screenshot</p>
            <h2 class="section-shell__title">Approved visual</h2>
          </div>
        </div>
        <div class="brand-assets">
          <div class="asset">
            <img src={override.screenshot} alt={`${tool.name} screenshot`} loading="lazy" />
            <span class="asset-label">Editorial screenshot</span>
          </div>
        </div>
      </section>
    )}

    <footer class="press-footer">
      {snapshot && (
        <p>
          {snapshotMeta.lockLabel}: {snapshot.lockSha256?.slice(0, 12)}
          {snapshotObservedAt && ` | ${snapshotMeta.snapshotLabel}: ${snapshotObservedAt}`}
        </p>
      )}
      {press?.boilerplate?.forbiddenPhrases?.length > 0 && (
        <p class="forbidden">Editorial notes: avoid {press.boilerplate.forbiddenPhrases.join(", ")}</p>
      )}
    </footer>
  </div>
</Base>

<style>
  .press-page {
    display: grid;
    gap: 1.5rem;
  }

  .back-link {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .claim-evidence {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .quote p,
  .rule-box p,
  .offer p,
  .comparable p {
    color: var(--color-text-muted);
  }

  .quote cite,
  .offer-constraints,
  .asset-label,
  .press-footer,
  .forbidden {
    color: var(--color-text-dim);
  }

  .press-footer {
    display: grid;
    gap: 0.35rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
</style>
