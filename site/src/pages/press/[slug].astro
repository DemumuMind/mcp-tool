---
import Base from "../../layouts/Base.astro";
import overrides from "../../data/overrides.json";
import fs from "node:fs";
import path from "node:path";
import { getPressData, getProofData, getPublicAssetLinks, getSnapshotMeta, getToolBySlug, loadSnapshot } from "../../lib/marketir/loader.mjs";

const overrideMap = overrides as Record<string, any>;

export function getStaticPaths() {
  const overridesBySlug = overrides as Record<string, any>;
  return Object.keys(overridesBySlug)
    .filter((slug) => overridesBySlug[slug]?.publicProof === true)
    .map((slug) => ({
      slug,
      tool: getToolBySlug(slug),
    }))
    .filter(({ tool }) => tool)
    .map(({ slug, tool }) => ({
      params: { slug },
      props: { slug, tool },
    }));
}

const { slug, tool } = Astro.props;
const override = overrideMap[slug] || {};
const press = getPressData(slug) || tool.press;
const proofData = getProofData(slug);
const snapshot = loadSnapshot();
const snapshotMeta = getSnapshotMeta(snapshot);
const publicAssetLinks = getPublicAssetLinks(slug);

let facts: any = null;
try {
  const factsPath = path.join(process.cwd(), "src/data/github-facts", `${slug}.json`);
  facts = JSON.parse(fs.readFileSync(factsPath, "utf8"));
} catch {}

const orgUrl = `https://github.com/DemumuMind/${slug}`;
---

<Base title={`${tool.name} - Press`} description={press?.boilerplate?.projectDescription || tool.positioning?.oneLiner || ""} currentPath={`/press/${slug}/`}>
  <div class="press-page">
    <a href="/press/" class="back-link">&larr; All press pages</a>

    <section class="press-hero">
      <div>
        <p class="eyebrow">Verified story package</p>
        <h1>{tool.name}</h1>
        <p class="one-liner">{tool.positioning?.oneLiner}</p>
        <div class="badges">
          {override.stability && <span class={`badge badge-${override.stability}`}>{override.stability}</span>}
          {override.kind && <span class="badge badge-kind">{override.kind}</span>}
        </div>
      </div>
      <div class="press-hero__actions">
        {publicAssetLinks.find((link) => link.kind === "presskit") && (
          <a href={publicAssetLinks.find((link) => link.kind === "presskit").href} class="btn btn-primary" rel="noopener">Press kit</a>
        )}
        {publicAssetLinks.find((link) => link.kind === "machine-readable") && (
          <a href={publicAssetLinks.find((link) => link.kind === "machine-readable").href} class="btn btn-secondary" rel="noopener">Machine-readable</a>
        )}
        <a href={`/proof/${slug}/`} class="btn btn-secondary">Proof page</a>
      </div>
    </section>

    {press?.boilerplate?.projectDescription && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Narrative brief</p>
            <h2 class="section-shell__title">About the project</h2>
          </div>
        </div>
        <div class="rule-box">
          <p>{press.boilerplate.projectDescription}</p>
          {press.boilerplate.founderBio && <p>{press.boilerplate.founderBio}</p>}
          {press.boilerplate.preferredNouns?.length > 0 && (
            <p>Preferred terms: {press.boilerplate.preferredNouns.join(", ")}</p>
          )}
        </div>
      </section>
    )}

    {proofData?.proven?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Press-safe proof</p>
            <h2 class="section-shell__title">Verified claims</h2>
          </div>
        </div>
        <div class="claims-list">
          {proofData.proven.map((claim: any) => (
            <article class="claim">
              <div class="claim-statement">{claim.statement}</div>
              {claim.evidence?.length > 0 && (
                <div class="claim-evidence">
                  {claim.evidence.map((evidence: any) => (
                    <span class="tag">
                      {evidence.url ? (
                        <a href={evidence.url} target="_blank" rel="noopener">{evidence.type}: {evidence.id.split(".").pop()}</a>
                      ) : evidence.path ? (
                        <a href={`/marketir/evidence/${evidence.path.split("/").pop()}`} target="_blank" rel="noopener">{evidence.type}: {evidence.id.split(".").pop()}</a>
                      ) : (
                        <span>{evidence.type}: {evidence.id.split(".").pop()}</span>
                      )}
                    </span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {press?.quotes?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Approved quote bank</p>
            <h2 class="section-shell__title">Quotes</h2>
          </div>
        </div>
        <div class="quotes-list">
          {press.quotes.map((quote: any) => (
            <blockquote class="quote">
              <p>"{quote.text}"</p>
              {quote.attribution && <cite>- {quote.attribution}{quote.role ? `, ${quote.role}` : ""}</cite>}
            </blockquote>
          ))}
        </div>
      </section>
    )}

    {press?.comparables?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Positioning</p>
            <h2 class="section-shell__title">Comparables</h2>
          </div>
        </div>
        <div class="comparables-list">
          {press.comparables.map((comparable: any) => (
            <article class="comparable">
              <strong>Similar to {comparable.target}</strong>
              <p>{comparable.distinction}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    {press?.partnerOffers?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Partner pack</p>
            <h2 class="section-shell__title">Partner offers</h2>
          </div>
        </div>
        <div class="offers-list">
          {press.partnerOffers.map((offer: any) => (
            <article class="offer">
              <span class="offer-type">{offer.type}</span>
              <p>{offer.description}</p>
              {offer.constraints && <p class="offer-constraints">{offer.constraints}</p>}
            </article>
          ))}
        </div>
      </section>
    )}

    {facts && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Observed facts</p>
            <h2 class="section-shell__title">GitHub facts</h2>
          </div>
        </div>
        <div class="facts-grid">
          {facts.stars != null && <div class="fact"><span class="fact-value">{facts.stars}</span><span class="fact-label">Stars</span></div>}
          {facts.forks != null && <div class="fact"><span class="fact-value">{facts.forks}</span><span class="fact-label">Forks</span></div>}
          {facts.openIssues != null && <div class="fact"><span class="fact-value">{facts.openIssues}</span><span class="fact-label">Open issues</span></div>}
          {facts.releasesLast90d != null && <div class="fact"><span class="fact-value">{facts.releasesLast90d}</span><span class="fact-label">Releases (90d)</span></div>}
          {facts.latestRelease && <div class="fact"><span class="fact-value">{facts.latestRelease.tag}</span><span class="fact-label">Latest release</span></div>}
          {facts.license && <div class="fact"><span class="fact-value">{facts.license}</span><span class="fact-label">License</span></div>}
        </div>
      </section>
    )}

    {press?.contacts?.length > 0 && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Contacts</p>
            <h2 class="section-shell__title">Contact points</h2>
          </div>
        </div>
        <div class="contacts-list">
          {press.contacts.map((contact: any) => (
            <div class="contact">
              <span class="contact-method">{contact.method}</span>
              {contact.href ? (
                <a href={contact.href} target="_blank" rel="noopener">{contact.label || contact.value}</a>
              ) : (
                <span>{contact.label || contact.value}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="section">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Resources</p>
          <h2 class="section-shell__title">Distribution-ready assets</h2>
        </div>
      </div>
      <div class="downloads">
        {publicAssetLinks.map((link) => (
          <a href={link.href} class="btn btn-secondary" rel="noopener">{link.label}</a>
        ))}
        <a href={orgUrl} class="btn btn-secondary" rel="noopener">GitHub</a>
        <a href={`/tools/${slug}/`} class="btn btn-secondary">Tool page</a>
      </div>
    </section>

    {override.screenshot && (
      <section class="section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Brand asset</p>
            <h2 class="section-shell__title">Approved screenshot</h2>
          </div>
        </div>
        <div class="brand-assets">
          <div class="asset">
            <img src={override.screenshot} alt={`${tool.name} screenshot`} loading="lazy" />
            <span class="asset-label">Editorial screenshot</span>
          </div>
        </div>
      </section>
    )}

    <footer class="press-footer">
      {snapshot && <p>{snapshotMeta.lockLabel}: {snapshot.lockSha256?.slice(0, 12)} | {snapshotMeta.snapshotLabel}: {new Date(snapshot.fetchedAt).toLocaleDateString("en-US", { dateStyle: "medium" })}</p>}
      {press?.boilerplate?.forbiddenPhrases?.length > 0 && (
        <p class="forbidden">Avoid: {press.boilerplate.forbiddenPhrases.join(", ")}</p>
      )}
    </footer>
  </div>
</Base>

<style>
  .press-page {
    display: grid;
    gap: 1.5rem;
  }

  .back-link {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .press-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: end;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      var(--color-surface);
  }

  .press-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4vw, 4rem);
    letter-spacing: -0.05em;
  }

  .one-liner {
    margin-top: 0.8rem;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .badges,
  .claim-evidence {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .press-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .quote p,
  .rule-box p,
  .offer p,
  .comparable p {
    color: var(--color-text-muted);
  }

  .quote cite,
  .offer-constraints,
  .asset-label,
  .press-footer,
  .forbidden {
    color: var(--color-text-dim);
  }

  .press-footer {
    display: grid;
    gap: 0.35rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 900px) {
    .press-hero {
      grid-template-columns: 1fr;
    }

    .press-hero__actions {
      justify-content: flex-start;
    }
  }
</style>
