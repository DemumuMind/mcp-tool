---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import overrides from "../../data/overrides.json";
import { getToolBySlug } from "../../lib/marketir/loader.mjs";
import { withBase } from "../../lib/site-paths";

const overrideMap = overrides as Record<string, any>;
const pressTools = Object.keys(overrideMap)
  .filter((slug) => overrideMap[slug]?.publicProof === true)
  .map((slug) => {
    const tool = getToolBySlug(slug);
    if (!tool) return null;
    return {
      slug,
      name: tool.name,
      oneLiner: tool.positioning?.oneLiner || "",
      quoteCount: tool.press?.quotes?.length || 0,
    };
  })
  .filter(Boolean);
---

<Base title="Press Reference - DemumuMind MCP" description="Secondary reference surface for press-ready marketplace listings." currentPath="/press/">
  <div class="page-content">
    <PageHero
      eyebrow="Reference surface"
      title="Press reference for marketplace-ready MCP products"
      lede="This is a secondary reference layer for press-ready listings. Primary discovery should still start in the marketplace, not here."
      meta={[`${pressTools.length} press-ready listings`, "Reference surface", "Marketplace-linked"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
      </Fragment>
    </PageHero>

    <div class="tools-grid">
      {pressTools.map((tool) => (
        <a href={withBase(`/press/${tool.slug}/`)} class="tool-card">
          <h2>{tool.name}</h2>
          <p>{tool.oneLiner || "Reference-ready narrative and quote surface."}</p>
          <div class="card-meta">
            <span>{tool.quoteCount} quotes</span>
            <span>Reference</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
