---
export const prerender = true;

import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { getMarketplaceContent } from "../lib/content/marketplace.ts";
import { withBase } from "../lib/site-paths";

const content = getMarketplaceContent();
const stats = content.stats;
---

<Base
  title="About - DemumuMind MCP"
  description="What DemumuMind MCP is building, who the marketplace is for, and why the catalog emphasizes compatibility, adoption, and transparent signals."
  currentPath="/about/"
>
  <div class="page-content">
    <PageHero
      eyebrow="About the marketplace"
      title="A practical marketplace for MCP builders and adopters."
      lede="DemumuMind MCP is a discovery layer for real MCP servers, clients, desktop apps, and tooling. The goal is not to look official. The goal is to make the ecosystem legible."
      meta={[
        `${stats.totalListings} public listings`,
        `${stats.verifiedListings} automatic verified`,
        `${stats.commercialListings} commercial surfaces`,
      ]}
      proofItems={["Search-first discovery", "Builder-grade signals", "Platform-aware navigation"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">How ranking works</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Positioning</p>
          <h2 class="section-shell__title">Broad marketplace, builder depth</h2>
        </div>
      </div>
      <p class="section-subheading">
        The product behaves like a broad marketplace on the surface, but each listing still pushes the user toward adoption signals:
        compatibility, docs, install path, freshness, pricing posture, and related alternatives.
      </p>
      <div class="about-grid">
        <article class="about-card">
          <h3>Who it helps</h3>
          <p>MCP builders, evaluators, and teams comparing tools before adoption.</p>
        </article>
        <article class="about-card">
          <h3>What it covers</h3>
          <p>Servers, clients, desktop apps, SDKs, tooling, curated collections, and platform hubs.</p>
        </article>
        <article class="about-card">
          <h3>What it avoids</h3>
          <p>No paid placement logic, no user reviews, and no opaque trust claims hidden behind marketing copy.</p>
        </article>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Principles</p>
          <h2 class="section-shell__title">How DemumuMind MCP operates</h2>
        </div>
      </div>
      <ul>
        <li><strong>Marketplace first:</strong> find and adopt tools quickly, not after a maze of editorial copy.</li>
        <li><strong>Transparency first:</strong> automatic verified, quality score, and category logic are explained publicly.</li>
        <li><strong>Compatibility matters:</strong> platform hubs and technical facets are part of discovery, not an afterthought.</li>
        <li><strong>Commercial is allowed:</strong> official homepage and docs are enough if the MCP surface is clear.</li>
      </ul>
    </section>
  </div>
</Base>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .about-card {
    display: grid;
    gap: 0.6rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
  }
</style>
