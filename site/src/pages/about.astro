---
export const prerender = true;

import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { getMarketplaceContent } from "../lib/content/marketplace.ts";
import { withBase } from "../lib/site-paths";

const content = getMarketplaceContent();
const stats = content.stats;
const formatNumber = (value: number) => new Intl.NumberFormat("en-US").format(value);
---

<Base
  title="About - DemumuMind MCP"
  description="What DemumuMind MCP is for, who it helps, and how the catalog is put together."
  currentPath="/about/"
>
  <div class="page-content">
    <PageHero
      eyebrow="About the marketplace"
      title="A practical marketplace for finding MCP tools."
      lede="DemumuMind MCP helps people browse real MCP servers, apps, clients, and supporting tools without wading through vague positioning or missing setup context."
      meta={[
        `${formatNumber(stats.totalListings)} listed tools`,
        `${formatNumber(stats.verifiedListings)} verified tools`,
        `${formatNumber(stats.commercialListings)} commercial tools`,
      ]}
      proofItems={["Clear discovery", "Visible quality cues", "Platform-aware navigation"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">How ranking works</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Positioning</p>
          <h2 class="section-shell__title">Wide catalog, practical detail</h2>
        </div>
      </div>
      <p class="section-subheading">
        The catalog is meant to stay broad without becoming shallow. Each listing should quickly answer the basics:
        what the tool does, where it runs, how to try it, and what level of confidence the public signals justify.
      </p>
      <div class="about-grid">
        <article class="about-card">
          <h3>Who it helps</h3>
          <p>Builders, evaluators, and teams trying to choose MCP tools with less guesswork.</p>
        </article>
        <article class="about-card">
          <h3>What it covers</h3>
          <p>Servers, clients, desktop apps, SDKs, supporting utilities, curated collections, and platform hubs.</p>
        </article>
        <article class="about-card">
          <h3>What it avoids</h3>
          <p>No paid placement logic, no review-score theater, and no trust claims that cannot be traced back to public evidence.</p>
        </article>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Principles</p>
          <h2 class="section-shell__title">How DemumuMind MCP operates</h2>
        </div>
      </div>
      <ul>
        <li><strong>Discovery first:</strong> users should understand the option set quickly, not read through a maze of marketing copy.</li>
        <li><strong>Public logic:</strong> verified status, score inputs, and category rules should be explained in plain language.</li>
        <li><strong>Compatibility matters:</strong> platform fit and runtime context belong in discovery, not as an afterthought.</li>
        <li><strong>Commercial is welcome:</strong> official docs and a clear MCP surface are enough for inclusion.</li>
      </ul>
    </section>
  </div>
</Base>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .about-card {
    display: grid;
    gap: 0.6rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
  }
</style>
