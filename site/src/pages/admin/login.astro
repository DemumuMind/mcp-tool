---
export const prerender = false;

import StatusPill from "../../components/admin/StatusPill.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { canUseBootstrapAuth } from "../../lib/admin/session.mjs";
import { withBase } from "../../lib/site-paths";

const nextPath = Astro.url.searchParams.get("next") || withBase("/admin/");
const bootstrapMode = canUseBootstrapAuth();

if (Astro.locals.isAdminAuthenticated) {
  return Astro.redirect(nextPath);
}
---

<AdminLayout title="Admin Login" currentPath="/admin/login/">
  <section class="admin-login reveal-stage">
    <div class="admin-login__copy">
      <StatusPill label="Internal access" tone="system" />
      <span class="admin-login__eyebrow">Session bootstrap</span>
      <h1>Enter the control plane with a real operator session.</h1>
      <p>
        Admin access is now backed by a durable control-plane store and signed cookie sessions. The login flow
        resolves the operator role from the stored account and routes the browser into the live admin workspaces.
      </p>
      <ul>
        <li>Owner sessions land on release gates and elevated approvals.</li>
        <li>Operators land on queue health, command center actions, and rerun follow-ups.</li>
        <li>Reviewers land on moderation, compliance, and staged decision worklists.</li>
        <li>Analysts land on telemetry anomalies, quality regressions, and recommendation feeds.</li>
      </ul>
      <p class="admin-login__hint">
        {bootstrapMode
          ? "Bootstrap auth is available in local development when a user has no password hash yet."
          : "Production requires stored password hashes for internal accounts."}
      </p>
    </div>

    <div class="admin-login__card">
      <div class="admin-login__card-header">
        <span class="admin-login__kicker">Live auth flow</span>
        <h2>Admin session handshake</h2>
      </div>

      <form
        class="admin-login__form"
        method="post"
        action={withBase("/api/admin/auth/session/")}
        data-admin-login-form
        data-testid="admin-login-form"
        data-next={nextPath}
      >
        <label>
          Operator email
          <input type="email" name="email" placeholder="owner@demumumind.internal" autocomplete="username" required data-testid="admin-login-email" />
        </label>
        <label>
          Password
          <input type="password" name="password" placeholder="Stored admin credential" autocomplete="current-password" required data-testid="admin-login-password" />
        </label>

        <button type="submit" data-testid="admin-login-submit">Start admin session</button>
        <p class="admin-login__status" data-admin-form-status data-testid="admin-login-status"></p>
      </form>

      <div class="admin-login__role-grid" aria-label="Roles resolved after sign-in">
        <span>Owner</span>
        <span>Operator</span>
        <span>Reviewer</span>
        <span>Analyst</span>
      </div>

      <p class="admin-login__note">
        Credentials are resolved against the internal control-plane store and the session is issued through
        <code>/api/admin/auth/session/</code>.
      </p>
    </div>
  </section>
</AdminLayout>

<style>
  .admin-login {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.9fr);
    gap: 1rem;
  }

  .admin-login__copy,
  .admin-login__card {
    display: grid;
    gap: 0.85rem;
    padding: 1.2rem;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.012)),
      rgba(10, 14, 19, 0.9);
  }

  .admin-login__eyebrow,
  .admin-login__kicker,
  .admin-login__hint {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .admin-login__copy h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5vw, 4rem);
    letter-spacing: -0.05em;
    line-height: 0.97;
  }

  .admin-login__copy p,
  .admin-login__copy li,
  .admin-login__note {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .admin-login__copy ul {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.55rem;
  }

  .admin-login__card-header {
    display: grid;
    gap: 0.3rem;
  }

  .admin-login__card-header h2 {
    font-size: 1.3rem;
    letter-spacing: -0.04em;
  }

  .admin-login__form {
    display: grid;
    gap: 0.85rem;
  }

  .admin-login__form label {
    display: grid;
    gap: 0.45rem;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .admin-login__form input,
  .admin-login__role-grid {
    min-height: 3rem;
    padding: 0.75rem 0.9rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
    font-family: var(--font-sans);
  }

  .admin-login__form button {
    min-height: 3rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(108, 224, 255, 0.24);
    background: rgba(108, 224, 255, 0.12);
    color: var(--color-text);
    cursor: pointer;
  }

  .admin-login__role-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    align-items: center;
  }

  .admin-login__role-grid span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.2rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
  }

  .admin-login__status {
    min-height: 1.2rem;
    margin: 0;
    font-size: 0.88rem;
  }

  .admin-login__status[data-tone="danger"] {
    color: var(--color-danger);
  }

  .admin-login__status[data-tone="success"] {
    color: var(--color-success);
  }

  .admin-login__status[data-tone="system"] {
    color: var(--color-system);
  }

  .admin-login__note code {
    font-family: var(--font-mono);
    color: var(--color-system);
  }

  @media (max-width: 920px) {
    .admin-login {
      grid-template-columns: 1fr;
    }
  }
</style>
