---
export const prerender = true;

import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { kit } from "../lib/kit";
import { withBase } from "../lib/site-paths";

const repoUrl = `https://github.com/${kit.repo.marketing || "DemumuMind/mcp-tool"}`;
const issueUrl = `${repoUrl}/issues/new?title=${encodeURIComponent("Category request: new MCP marketplace taxonomy slot")}`;
---

<Base
  title="Request Category - DemumuMind MCP"
  description="Request new taxonomy coverage when the marketplace does not yet describe an MCP workflow, client, or platform correctly."
  currentPath="/request-category/"
>
  <div class="page-content">
    <PageHero
      eyebrow="Category request"
      title="Ask for better category coverage."
      lede="The first release groups tools automatically, but category requests still matter. Use this page when a workflow, platform, or tool segment is clearly underrepresented."
      meta={["Automatic categories", "GitHub issue intake", "Catalog feedback"]}
    >
      <Fragment slot="actions">
        <a href={issueUrl} class="btn btn-primary" rel="noopener">Open GitHub issue</a>
        <a href={withBase("/submit/")} class="btn btn-secondary">Submit a tool</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">What to include</p>
          <h2 class="section-shell__title">Show the gap clearly</h2>
        </div>
      </div>
      <ul>
        <li>The workflow or product segment that needs a category.</li>
        <li>Examples of tools that do not fit well in the current taxonomy.</li>
        <li>The client, runtime, or platform context that makes this category useful.</li>
      </ul>
    </section>
  </div>
</Base>
