---
export const prerender = true;

import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { withBase } from "../lib/site-paths";
---

<Base title="Start - DemumuMind MCP" description="Secondary guided entrypoint into the MCP marketplace." currentPath="/start/">
  <div class="page-content">
    <PageHero
      eyebrow="Marketplace guide"
      title="Start from the marketplace, then narrow fast."
      lede="This page is now a lightweight secondary guide. The real product surface is the marketplace itself: browse, categories, platforms, and dossiers."
      meta={["Marketplace guide", "Secondary surface", "Use-case first"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/categories/")} class="btn btn-secondary">Open categories</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
      </Fragment>
    </PageHero>

    <div class="platform-hub-grid">
      <a href={withBase("/tools/?platform=claude")} class="collection-item">
        <span class="collection-item-name">Start with a client</span>
        <span class="collection-item-desc">Use platform hubs if your workflow begins from Claude, Cursor, VS Code, ChatGPT, or Gemini.</span>
      </a>
      <a href={withBase("/categories/")} class="collection-item">
        <span class="collection-item-name">Start with a category</span>
        <span class="collection-item-desc">Use categories if you already know whether you need servers, infrastructure, voice, web, or developer tools.</span>
      </a>
      <a href={withBase("/collections/")} class="collection-item">
        <span class="collection-item-name">Start with a collection</span>
        <span class="collection-item-desc">Collections are the guided paths when you want a curated stack instead of a full marketplace browse.</span>
      </a>
      <a href={withBase("/stats/")} class="collection-item">
        <span class="collection-item-name">Start with market health</span>
        <span class="collection-item-desc">Use stats when you want to see category depth, verification coverage, and ecosystem shape before picking a lane.</span>
      </a>
    </div>
  </div>
</Base>
