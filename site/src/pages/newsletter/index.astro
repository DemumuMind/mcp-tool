---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import post from "../../data/newsletter.json";
import { withBase } from "../../lib/site-paths";
---

<Base title={`Newsletter - ${post.title}`} description="Secondary marketplace editorial dispatch." currentPath="/newsletter/">
  <div class="page-content">
    <PageHero
      eyebrow="Marketplace dispatch"
      title="Newsletter as a secondary editorial surface"
      lede="The newsletter remains useful as a recurring ecosystem dispatch, but discovery should still start in the marketplace and stats surfaces."
      meta={[post.issue, post.title, "Marketplace-linked"]}
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/stats/")} class="btn btn-secondary">Open stats</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
      </Fragment>
    </PageHero>

    <article class="post">
      <header class="post-header">
        <span class="issue-badge">{post.issue}</span>
        <h2>{post.title}</h2>
        {post.lede && <p class="lede">{post.lede}</p>}
      </header>

      <div class="post-body">
        {(post.sections ?? []).map((section: any) => (
          <section class="doc-section">
            <h3>{section.heading}</h3>
            {section.body.split("\n\n").map((paragraph: string) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>
    </article>
  </div>
</Base>
