---
export const prerender = true;

import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/site-paths";
---

<Base
  title="Clearance Reference - DemumuMind MCP"
  description="Secondary reference for namespace clearance before shipping MCP brands, products, and packages."
  currentPath="/clearance/"
  routeFamily="reference"
>
  <div class="clearance-page">
    <PageHero
      eyebrow="Clearance reference"
      title="Check naming risk before a brand becomes a migration problem"
      lede="This page now acts as a supporting reference for naming and reservation checks. Discovery should still begin in the marketplace; use clearance when you are already narrowing a product, package, or tool identity."
      meta={["GREEN / YELLOW / RED output", "Local-first", "Reservation links included"]}
      asideTitle="Where it fits"
      asideBody="Use clearance after tool/category/platform discovery, when you need brand and package confidence before launch or rename decisions."
    >
      <Fragment slot="actions">
        <a href={withBase("/tools/")} class="btn btn-primary">Browse tools</a>
        <a href={withBase("/methodology/")} class="btn btn-secondary">Open methodology</a>
        <a href="https://github.com/DemumuMind/clearance-opinion-engine" class="btn btn-secondary" rel="noopener">GitHub</a>
        <a href="https://www.npmjs.com/package/@demumumind/clearance-opinion-engine" class="btn btn-secondary" rel="noopener">npm package</a>
      </Fragment>
    </PageHero>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">How to use this page</p>
          <h2 class="section-shell__title">Validate naming risk after you shortlist the product</h2>
        </div>
      </div>
      <ul class="ops-list">
        <li>Use browse and dossiers first to understand the product, market lane, and adoption context.</li>
        <li>Use this page when you need namespace availability before shipping a new tool, package, or rename.</li>
        <li>Use methodology and stats if you need the broader marketplace framing around naming and launch discipline.</li>
      </ul>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Scope</p>
          <h2 class="section-shell__title">What it checks</h2>
        </div>
      </div>
      <div class="clearance-grid">
        <div class="clearance-card">
          <h3>Included</h3>
          <ul>
            <li>Namespace availability across npm, PyPI, GitHub, crates.io, Docker Hub, Hugging Face, and domains.</li>
            <li>Phonetic, homoglyph, and fuzzy variants to surface near-conflicts.</li>
            <li>Deterministic GREEN / YELLOW / RED scoring with explainable reasoning.</li>
            <li>Reservation links so you can claim handles immediately.</li>
            <li>Local execution with no API keys required for the core scan.</li>
          </ul>
        </div>
        <div class="clearance-card">
          <h3>Not included</h3>
          <ul>
            <li>Trademark database search across USPTO, EUIPO, or WIPO.</li>
            <li>Legal advice or legal opinion.</li>
            <li>Automatic namespace registration or claims.</li>
            <li>Replacement for trademark counsel.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Quickstart</p>
          <h2 class="section-shell__title">Run a scan in seconds</h2>
        </div>
      </div>
      <div class="steps-box">
        <p>One-off execution:</p>
        <pre><code>npx @demumumind/clearance-opinion-engine check my-tool-name</code></pre>
        <p>Install for repeated use:</p>
        <pre><code>npm install -g @demumumind/clearance-opinion-engine
coe check my-tool-name --radar --suggest</code></pre>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Decision model</p>
          <h2 class="section-shell__title">How the tiers work</h2>
        </div>
      </div>
      <div class="clearance-grid">
        <div class="clearance-card">
          <span class="badge badge-stable">Green</span>
          <p>All namespaces available. No direct conflicts detected. Safe to reserve now.</p>
        </div>
        <div class="clearance-card">
          <span class="badge badge-beta">Yellow</span>
          <p>Some concerns surfaced. Review near-conflicts before committing the brand.</p>
        </div>
        <div class="clearance-card">
          <span class="badge badge-experimental">Red</span>
          <p>Direct conflicts detected. Rename before the cost compounds.</p>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .clearance-page {
    display: grid;
    gap: 1.5rem;
  }

  .clearance-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .clearance-card {
    display: grid;
    gap: 0.8rem;
    padding: 1rem;
  }

  .clearance-card h3 {
    font-size: 1rem;
  }

  .clearance-card ul {
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  .clearance-card li + li {
    margin-top: 0.4rem;
  }

  .steps-box {
    display: grid;
    gap: 0.8rem;
    padding: 1rem;
  }

  @media (max-width: 720px) {
    .clearance-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
