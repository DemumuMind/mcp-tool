---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import MarketplaceCard from "../../components/MarketplaceCard.astro";
import { getMarketplaceContent } from "../../lib/content/marketplace.ts";

const content = getMarketplaceContent();
const kindOptions = [...new Set(content.catalog.primary.map((entry) => entry.kind))].sort();

function getDaysSince(dateValue: string) {
  const timestamp = dateValue ? new Date(dateValue).getTime() : 0;
  if (!timestamp) return Number.POSITIVE_INFINITY;
  return Math.max(0, Math.floor((Date.now() - timestamp) / 86_400_000));
}
---

<Base
  title="Browse Tools - DemumuMind MCP"
  description="Browse a compatibility-aware MCP marketplace with shareable filters, saved views, and dossier pages."
  currentPath="/tools/"
>
  <PageHero
    eyebrow="Browse tools"
    title="Search the MCP marketplace with builder-grade filters."
    lede="Use one browse surface for search, categories, compatibility, pricing, freshness, verified signals, and compare-ready discovery."
    meta={[
      `${content.catalog.primary.length} primary listings`,
      `${content.stats.verifiedListings} verified`,
      `${content.platforms.length} platform hubs`,
    ]}
  />

  <section class="facet-toolbar">
    <div class="search-wrapper">
      <input id="filter-q" class="search-input" type="text" placeholder="Search tools, tags, categories, or descriptions" />
    </div>
    <div class="filters-grid">
      <select id="filter-category" class="filter-select">
        <option value="">All categories</option>
        {content.categories.map((category) => <option value={category.slug}>{category.title}</option>)}
      </select>
      <select id="filter-platform" class="filter-select">
        <option value="">All platforms</option>
        {content.platforms.map((platform) => <option value={platform.slug}>{platform.title}</option>)}
      </select>
      <select id="filter-kind" class="filter-select">
        <option value="">All types</option>
        {kindOptions.map((kind) => <option value={kind}>{kind}</option>)}
      </select>
      <select id="filter-pricing" class="filter-select">
        <option value="">All pricing</option>
        <option value="open-source">Open Source</option>
        <option value="free">Free</option>
        <option value="commercial">Commercial</option>
      </select>
      <select id="filter-freshness" class="filter-select">
        <option value="">Any freshness</option>
        <option value="new">New this month</option>
        <option value="recent">Updated this quarter</option>
      </select>
      <select id="filter-sort" class="filter-select">
        <option value="quality">Best quality</option>
        <option value="compatibility">Broad client support</option>
        <option value="newest">Recently updated</option>
        <option value="stars">Popularity</option>
        <option value="name">Name A-Z</option>
      </select>
      <label class="toggle-label">
        <input id="filter-verified" type="checkbox" />
        <span>Verified only</span>
      </label>
    </div>
  </section>

  <section class="saved-view-panel">
    <div class="saved-view-actions">
      <span class="results-count">Saved views</span>
      <button class="btn btn-secondary" type="button" data-save-view="builders">Save builders view</button>
      <button class="btn btn-secondary" type="button" data-load-view="builders">Load builders view</button>
      <button class="btn btn-secondary" type="button" data-save-view="hosted">Save hosted view</button>
      <button class="btn btn-secondary" type="button" data-load-view="hosted">Load hosted view</button>
      <button class="btn btn-secondary" type="button" id="clear-saved-views">Clear saved views</button>
    </div>
    <div class="active-filter-strip" id="active-filter-strip"></div>
  </section>

  <div class="results-count" id="results-count"></div>
  <div class="browse-grid" id="browse-grid">
    {content.catalog.primary.map((entry) => (
      <div
        class="browse-grid__item"
        data-name={entry.name.toLowerCase()}
        data-summary={`${entry.summary} ${entry.description} ${entry.tags.join(" ")}`.toLowerCase()}
        data-category={entry.primaryCategory}
        data-platform={entry.compatibility.platforms.map((platform) => platform.slug).join(" ")}
        data-platform-count={entry.compatibility.platforms.length}
        data-kind={entry.kind}
        data-pricing={entry.pricing}
        data-verified={entry.quality.verified ? "1" : "0"}
        data-freshness={entry.isNew ? "new" : getDaysSince(entry.updatedAt) <= 90 ? "recent" : "steady"}
        data-quality={entry.quality.score}
        data-stars={entry.stars}
        data-updated={entry.updatedAt}
      >
        <MarketplaceCard entry={entry} />
      </div>
    ))}
  </div>
  <div class="marketplace-pagination">
    <button id="pagination-prev" class="btn btn-secondary" type="button">Previous</button>
    <span id="pagination-label" class="results-count"></span>
    <button id="pagination-next" class="btn btn-secondary" type="button">Next</button>
  </div>

  <script is:inline>
    const pageSize = 12;
    const savedViewsKey = "demumumind-mcp-saved-views";
    const grid = document.getElementById("browse-grid");
    const resultsCount = document.getElementById("results-count");
    const paginationPrev = document.getElementById("pagination-prev");
    const paginationNext = document.getElementById("pagination-next");
    const paginationLabel = document.getElementById("pagination-label");
    const activeFilterStrip = document.getElementById("active-filter-strip");
    const items = Array.from(grid.querySelectorAll(".browse-grid__item"));
    const controls = {
      q: document.getElementById("filter-q"),
      category: document.getElementById("filter-category"),
      platform: document.getElementById("filter-platform"),
      kind: document.getElementById("filter-kind"),
      pricing: document.getElementById("filter-pricing"),
      freshness: document.getElementById("filter-freshness"),
      sort: document.getElementById("filter-sort"),
      verified: document.getElementById("filter-verified"),
    };

    function readState() {
      const params = new URLSearchParams(window.location.search);
      return {
        q: params.get("q") || "",
        category: params.get("category") || "",
        platform: params.get("platform") || "",
        compatibility: params.get("compatibility") || "",
        type: params.get("type") || "",
        pricing: params.get("pricing") || "",
        freshness: params.get("freshness") || "",
        verified: params.get("verified") === "1",
        sort: params.get("sort") || "quality",
        page: Number(params.get("page") || "1"),
      };
    }

    function writeState(state) {
      const params = new URLSearchParams();
      if (state.q) params.set("q", state.q);
      if (state.category) params.set("category", state.category);
      if (state.platform) params.set("platform", state.platform);
      if (state.type) params.set("type", state.type);
      if (state.pricing) params.set("pricing", state.pricing);
      if (state.freshness) params.set("freshness", state.freshness);
      if (state.verified) params.set("verified", "1");
      if (state.sort && state.sort !== "quality") params.set("sort", state.sort);
      if (state.page > 1) params.set("page", String(state.page));
      const next = params.toString() ? `?${params.toString()}` : window.location.pathname;
      window.history.replaceState({}, "", next);
    }

    function applyStateToControls(state) {
      controls.q.value = state.q;
      controls.category.value = state.category;
      controls.platform.value = state.platform || state.compatibility;
      controls.kind.value = state.type;
      controls.pricing.value = state.pricing;
      controls.freshness.value = state.freshness;
      controls.sort.value = state.sort;
      controls.verified.checked = state.verified;
    }

    function renderActiveFilters(state) {
      activeFilterStrip.replaceChildren();
      const labels = [];
      if (state.q) labels.push(`Search: ${state.q}`);
      if (state.category) labels.push(`Category: ${state.category}`);
      if (state.platform) labels.push(`Platform: ${state.platform}`);
      if (state.type) labels.push(`Type: ${state.type}`);
      if (state.pricing) labels.push(`Pricing: ${state.pricing}`);
      if (state.freshness) labels.push(`Freshness: ${state.freshness}`);
      if (state.verified) labels.push("Verified only");

      if (labels.length === 0) {
        const empty = document.createElement("span");
        empty.className = "active-filter-chip";
        empty.textContent = "No active filters";
        activeFilterStrip.appendChild(empty);
        return;
      }

      for (const label of labels) {
        const pill = document.createElement("span");
        pill.className = "active-filter-chip";
        pill.textContent = label;
        activeFilterStrip.appendChild(pill);
      }
    }

    function readSavedViews() {
      try {
        return JSON.parse(localStorage.getItem(savedViewsKey) || "{}");
      } catch {
        return {};
      }
    }

    function writeSavedViews(savedViews) {
      localStorage.setItem(savedViewsKey, JSON.stringify(savedViews));
    }

    function collectState(pageOverride) {
      const requestedPage = pageOverride ?? readState().page ?? 1;
      return {
        q: controls.q.value.trim().toLowerCase(),
        category: controls.category.value,
        platform: controls.platform.value,
        type: controls.kind.value,
        pricing: controls.pricing.value,
        freshness: controls.freshness.value,
        verified: controls.verified.checked,
        sort: controls.sort.value,
        page: Math.max(1, requestedPage),
      };
    }

    function render(pageOverride) {
      const state = collectState(pageOverride);
      renderActiveFilters(state);

      const visible = items.filter((item) => {
        const matchesQuery =
          !state.q ||
          item.dataset.name.includes(state.q) ||
          item.dataset.summary.includes(state.q);
        const matchesCategory = !state.category || item.dataset.category === state.category;
        const matchesPlatform = !state.platform || item.dataset.platform.includes(state.platform);
        const matchesType = !state.type || item.dataset.kind === state.type;
        const matchesPricing = !state.pricing || item.dataset.pricing === state.pricing;
        const matchesFreshness = !state.freshness || item.dataset.freshness === state.freshness;
        const matchesVerified = !state.verified || item.dataset.verified === "1";
        return matchesQuery && matchesCategory && matchesPlatform && matchesType && matchesPricing && matchesFreshness && matchesVerified;
      });

      visible.sort((a, b) => {
        switch (state.sort) {
          case "compatibility":
            return Number(b.dataset.platformCount) - Number(a.dataset.platformCount) || Number(b.dataset.quality) - Number(a.dataset.quality);
          case "newest":
            return b.dataset.updated.localeCompare(a.dataset.updated);
          case "stars":
            return Number(b.dataset.stars) - Number(a.dataset.stars);
          case "name":
            return a.dataset.name.localeCompare(b.dataset.name);
          default:
            return Number(b.dataset.quality) - Number(a.dataset.quality);
        }
      });

      for (const item of items) {
        item.hidden = true;
      }

      const totalPages = Math.max(1, Math.ceil(visible.length / pageSize));
      const page = Math.min(state.page, totalPages);
      const start = (page - 1) * pageSize;
      const pageItems = visible.slice(start, start + pageSize);

      for (const item of pageItems) {
        item.hidden = false;
        grid.appendChild(item);
      }

      resultsCount.textContent = `${visible.length} tools found`;
      paginationLabel.textContent = `Page ${page} of ${totalPages}`;
      paginationPrev.disabled = page <= 1;
      paginationNext.disabled = page >= totalPages;
      writeState({ ...state, page });
    }

    const initialState = readState();
    applyStateToControls(initialState);
    render(initialState.page);

    Object.values(controls).forEach((control) => {
      control.addEventListener(control.type === "checkbox" ? "change" : "input", () => render(1));
      if (control.tagName === "SELECT") control.addEventListener("change", () => render(1));
    });

    document.querySelectorAll("[data-save-view]").forEach((button) => {
      button.addEventListener("click", () => {
        const savedViews = readSavedViews();
        savedViews[button.dataset.saveView] = collectState(1);
        writeSavedViews(savedViews);
      });
    });

    document.querySelectorAll("[data-load-view]").forEach((button) => {
      button.addEventListener("click", () => {
        const savedViews = readSavedViews();
        const state = savedViews[button.dataset.loadView];
        if (!state) return;
        applyStateToControls(state);
        render(state.page || 1);
      });
    });

    document.getElementById("clear-saved-views").addEventListener("click", () => {
      localStorage.removeItem(savedViewsKey);
    });

    paginationPrev.addEventListener("click", () => render(readState().page - 1));
    paginationNext.addEventListener("click", () => render(readState().page + 1));
  </script>
</Base>
