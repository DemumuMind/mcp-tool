---
import PageHero from "../../components/PageHero.astro";
import Base from "../../layouts/Base.astro";
import projects from "../../data/projects.json";
import RealityPills from "../../components/RealityPills.astro";
import proofs from "../../data/audit/proofs.json";
import { withBase } from "../../lib/site-paths";

const languages = [...new Set((projects as any[]).map((project: any) => project.language).filter(Boolean))].sort();
const stabilities = ["stable", "beta", "experimental"];
const kinds = [...new Set((projects as any[]).map((project: any) => project.kind).filter(Boolean))].sort();
const registeredCount = (projects as any[]).filter((project: any) => project.registered).length;
---

<Base
  title="Tools - DemumuMind"
  description="Browse MCP servers, desktop apps, and AI tooling from DemumuMind."
  currentPath="/tools/"
>
  <PageHero
    eyebrow="Curated registry"
    title="Browse operator-grade tools."
    lede="Compare install paths, proof signals, release posture, and editorial readiness across the DemumuMind catalog."
    meta={[
      `${registeredCount} registry-listed tools`,
      `${(projects as any[]).length - registeredCount} org-only repos`,
      "Filter by build, kind, proof, and stability",
    ]}
  />

  <div class="toolbar">
    <div class="search-wrapper">
      <input
        type="text"
        id="search"
        class="search-input"
        placeholder="Search tools, repos, tags, or descriptions"
        autocomplete="off"
      />
      <button id="search-clear" class="search-clear" aria-label="Clear search" hidden>&times;</button>
    </div>
    <div class="filter-group">
      <select id="filter-status" class="filter-select">
        <option value="">All status cues</option>
        <option value="verified">Verified only</option>
        <option value="concept">Concept only</option>
        <option value="needs-copy">Needs copy</option>
      </select>
      <select id="filter-build" class="filter-select">
        <option value="">All build proofs</option>
        <option value="npm">NPM / Node.js</option>
        <option value="python">Python</option>
        <option value="dotnet">.NET</option>
        <option value="cargo">Rust / Cargo</option>
        <option value="docker">Container</option>
      </select>
      <select id="filter-lang" class="filter-select">
        <option value="">All languages</option>
        {languages.map((language: string) => <option value={language}>{language}</option>)}
      </select>
      <select id="filter-kind" class="filter-select">
        <option value="">All types</option>
        {kinds.map((kind: string) => <option value={kind}>{kind}</option>)}
      </select>
      <select id="filter-stability" class="filter-select">
        <option value="">All stability</option>
        {stabilities.map((stability: string) => <option value={stability}>{stability}</option>)}
      </select>
      <select id="sort-by" class="filter-select">
        <option value="featured">Featured first</option>
        <option value="updated">Recently updated</option>
        <option value="stars">Most stars</option>
        <option value="name">Name A-Z</option>
      </select>
      <label class="toggle-label" title="Show tools that are not yet listed in the registry">
        <input type="checkbox" id="show-orgonly" />
        <span>Show org-only</span>
      </label>
    </div>
  </div>

  <div class="results-count" id="results-count"></div>

  <div class="project-grid" id="project-grid">
    {(projects as any[]).map((project: any) => (
      <article
        class={`project-card project-card--tool${project.deprecated ? " project-card--deprecated" : ""}`}
        data-name={project.name.toLowerCase()}
        data-desc={project.description.toLowerCase()}
        data-repo={project.repo}
        data-lang={project.language || ""}
        data-kind={project.kind || ""}
        data-stability={project.stability || ""}
        data-featured={project.featured ? "1" : "0"}
        data-stars={project.stars || 0}
        data-updated={project.updatedAt || ""}
        data-tags={(project.tags || []).join(" ").toLowerCase()}
        data-registered={project.registered ? "1" : "0"}
        data-deprecated={project.deprecated ? "1" : "0"}
        data-verified={proofs.find((proof: any) => proof.repo === project.repo)?.verified ? "1" : "0"}
        data-concept={proofs.find((proof: any) => proof.repo === project.repo)?.concept ? "1" : "0"}
        data-build={(proofs.find((proof: any) => proof.repo === project.repo)?.proofs || []).join(" ")}
        data-needs-copy={(project.tags || []).includes("needs-copy") ? "1" : "0"}
      >
        <div class="card-header">
          <div>
            <h3><a href={withBase(`/tools/${project.repo}/`)}>{project.name}</a></h3>
            <p class="project-card__repo">{project.repo}</p>
          </div>
          <div class="card-badges">
            {project.deprecated && <span class="badge badge-experimental">Deprecated</span>}
            {project.registered && !project.deprecated && <span class="badge badge-registered">Registry</span>}
            {project.stability && <span class={`badge badge-${project.stability}`}>{project.stability}</span>}
            {project.kind && <span class="badge badge-kind">{project.kind}</span>}
          </div>
        </div>

        <RealityPills
          verified={proofs.find((proof: any) => proof.repo === project.repo)?.verified || false}
          concept={proofs.find((proof: any) => proof.repo === project.repo)?.concept || false}
          proofs={proofs.find((proof: any) => proof.repo === project.repo)?.proofs || []}
        />

        <p>{project.tagline || project.description}</p>
        {project.install && <code class="install-line">{project.install}</code>}

        <div class="card-meta">
          {project.stars > 0 && <span class="meta-item">{project.stars} stars</span>}
          {project.language && <span class="meta-item">{project.language}</span>}
          {project.updatedAt && <span class="meta-item">Updated {new Date(project.updatedAt).toLocaleDateString("en-US")}</span>}
        </div>

        <div class="tags">
          {(project.tags || []).slice(0, 5).map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</Base>

<style>
  .project-card--tool {
    min-height: 100%;
  }

  .project-card--deprecated {
    opacity: 0.72;
    border-style: dashed;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .card-badges,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .project-card__repo {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .install-line {
    overflow-x: auto;
    white-space: nowrap;
  }

  .project-card[hidden] {
    display: none;
  }
</style>

<script>
  const grid = document.getElementById("project-grid");
  const cards = Array.from(grid.querySelectorAll(".project-card"));
  const search = document.getElementById("search");
  const clearButton = document.getElementById("search-clear");
  const languageFilter = document.getElementById("filter-lang");
  const kindFilter = document.getElementById("filter-kind");
  const stabilityFilter = document.getElementById("filter-stability");
  const statusFilter = document.getElementById("filter-status");
  const buildFilter = document.getElementById("filter-build");
  const sortBy = document.getElementById("sort-by");
  const showOrgOnly = document.getElementById("show-orgonly");
  const resultsCount = document.getElementById("results-count");

  function applyFilters() {
    const query = search.value.toLowerCase().trim();
    const language = languageFilter.value;
    const kind = kindFilter.value;
    const stability = stabilityFilter.value;
    const status = statusFilter.value;
    const build = buildFilter.value;
    const includeOrgOnly = showOrgOnly.checked;

    clearButton.hidden = !query;

    let visible = 0;
    let hiddenDeprecated = 0;

    for (const card of cards) {
      const matchesSearch =
        !query ||
        card.dataset.name.includes(query) ||
        card.dataset.desc.includes(query) ||
        card.dataset.repo.includes(query) ||
        card.dataset.tags.includes(query);
      const matchesLanguage = !language || card.dataset.lang === language;
      const matchesKind = !kind || card.dataset.kind === kind;
      const matchesStability = !stability || card.dataset.stability === stability;
      const matchesStatus =
        !status ||
        (status === "verified" && card.dataset.verified === "1") ||
        (status === "concept" && card.dataset.concept === "1") ||
        (status === "needs-copy" && card.dataset.needsCopy === "1");
      const matchesBuild = !build || (card.dataset.build || "").includes(build);
      const matchesRegistered = includeOrgOnly || card.dataset.registered === "1";
      const isDeprecated = card.dataset.deprecated === "1";
      const matchesDeprecated = !isDeprecated || includeOrgOnly || Boolean(query);

      const show =
        matchesSearch &&
        matchesLanguage &&
        matchesKind &&
        matchesStability &&
        matchesStatus &&
        matchesBuild &&
        matchesRegistered &&
        matchesDeprecated;

      card.hidden = !show;
      if (show) visible++;
      if (!show && isDeprecated && matchesSearch && matchesLanguage && matchesKind && matchesStability) {
        hiddenDeprecated++;
      }
    }

    let countText = `${visible} of ${cards.length} tools`;
    if (hiddenDeprecated > 0 && !includeOrgOnly) {
      countText += ` · ${hiddenDeprecated} deprecated hidden`;
    }
    resultsCount.textContent = countText;
    applySort();
  }

  function applySort() {
    const mode = sortBy.value;
    const visibleCards = cards.filter((card) => !card.hidden);

    visibleCards.sort((a, b) => {
      switch (mode) {
        case "featured": {
          const aFeatured = a.dataset.featured === "1" ? 1 : 0;
          const bFeatured = b.dataset.featured === "1" ? 1 : 0;
          if (aFeatured !== bFeatured) return bFeatured - aFeatured;
          return Number(b.dataset.stars || 0) - Number(a.dataset.stars || 0);
        }
        case "updated":
          return (b.dataset.updated || "").localeCompare(a.dataset.updated || "");
        case "stars":
          return Number(b.dataset.stars || 0) - Number(a.dataset.stars || 0);
        case "name":
          return (a.dataset.name || "").localeCompare(b.dataset.name || "");
        default:
          return 0;
      }
    });

    for (const card of visibleCards) {
      grid.appendChild(card);
    }
  }

  search.addEventListener("input", applyFilters);
  clearButton.addEventListener("click", () => {
    search.value = "";
    applyFilters();
    search.focus();
  });
  languageFilter.addEventListener("change", applyFilters);
  kindFilter.addEventListener("change", applyFilters);
  stabilityFilter.addEventListener("change", applyFilters);
  statusFilter.addEventListener("change", applyFilters);
  buildFilter.addEventListener("change", applyFilters);
  sortBy.addEventListener("change", applyFilters);
  showOrgOnly.addEventListener("change", applyFilters);

  document.addEventListener("keydown", (event) => {
    if (event.key === "/" && document.activeElement !== search) {
      event.preventDefault();
      search.focus();
    }
  });

  applyFilters();
</script>
