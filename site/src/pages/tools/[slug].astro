---
import Base from "../../layouts/Base.astro";
import PublicProof from "../../components/marketir/PublicProof.astro";
import RealityPanel from "../../components/RealityPanel.astro";
import TryItNow from "../../components/TryItNow.astro";
import projects from "../../data/projects.json";
import proofs from "../../data/audit/proofs.json";
import releases from "../../data/releases.json";
import overrides from "../../data/overrides.json";
import { getProofData, getPressData, loadSnapshot } from "../../lib/marketir/loader.mjs";
import fs from "node:fs";
import path from "node:path";

export function getStaticPaths() {
  return (projects as any[]).map((project: any) => ({
    params: { slug: project.repo },
    props: { project },
  }));
}

const { project } = Astro.props;
const orgUrl = `https://github.com/DemumuMind/${project.repo}`;
const toolProof = (proofs as any[]).find((proof: any) => proof.repo === project.repo);
const isRegistered = project.registered === true;
const isDeprecated = project.deprecated === true;
const hasInstall = Boolean(project.install);
const latestRelease = (releases as any[]).find((release: any) => release.repo === project.repo);
const hasRelease = Boolean(latestRelease);
const projectTags = new Set(project.tags || []);
const related = (projects as any[])
  .filter((candidate: any) => candidate.repo !== project.repo && (candidate.tags || []).some((tag: string) => projectTags.has(tag)))
  .slice(0, 3);

const toolOverride = (overrides as any)[project.repo];
const showProof = toolOverride?.publicProof === true;
const proofData = showProof ? getProofData(project.repo) : null;
const snapshot = showProof && proofData ? loadSnapshot() : null;
const pressData = showProof ? getPressData(project.repo) : null;
const presskitDir = path.resolve("public/presskit", project.repo);
const hasPresskit = showProof && fs.existsSync(presskitDir);

const statusSignals = [
  { label: isRegistered ? "Registry listed" : "Org-only", positive: isRegistered },
  { label: hasInstall ? "Install path" : "No install path", positive: hasInstall },
  { label: hasRelease ? "Release evidence" : "No release evidence", positive: hasRelease },
  { label: project.description ? "Documented" : "Sparse docs", positive: Boolean(project.description) },
];
---

<Base
  title={`${project.name} - DemumuMind`}
  description={project.tagline || project.description}
  currentPath={`/tools/${project.repo}/`}
>
  <div class="tool-profile">
    <a href="/tools/" class="back-link">&larr; Back to registry</a>

    <section class="tool-profile__hero">
      <div class="tool-profile__lead">
        <p class="eyebrow">Tool dossier</p>
        <h1>{project.name}</h1>
        <p class="tool-profile__lede">{project.tagline || project.description}</p>
        {project.description && project.tagline && project.tagline !== project.description && (
          <p class="tool-profile__body">{project.description}</p>
        )}

        <div class="tool-profile__badges">
          {isRegistered ? <span class="badge badge-registered">Registry</span> : <span class="badge badge-kind">Org-only</span>}
          {isDeprecated && <span class="badge badge-experimental">Deprecated</span>}
          {project.stability && <span class={`badge badge-${project.stability}`}>{project.stability}</span>}
          {project.kind && <span class="badge badge-kind">{project.kind}</span>}
          {project.language && <span class="badge badge-kind">{project.language}</span>}
          {latestRelease?.tag && <a href={latestRelease.url} target="_blank" rel="noopener noreferrer" class="release-tag">{latestRelease.tag}</a>}
        </div>

        <div class="tool-links">
          <a href={orgUrl} class="btn btn-primary" rel="noopener">View on GitHub</a>
          <a href={`${orgUrl}/issues`} class="btn btn-secondary" rel="noopener">Issues</a>
          <a href={`${orgUrl}/releases`} class="btn btn-secondary" rel="noopener">Releases</a>
          {showProof && pressData && <a href={`/press/${project.repo}/`} class="btn btn-secondary">Press page</a>}
          {hasPresskit && <a href={`/presskit/${project.repo}/`} class="btn btn-secondary">Press kit</a>}
        </div>
      </div>

      <aside class="tool-profile__side">
        <div class="tool-meta-grid">
          {project.stars > 0 && (
            <div class="meta-block">
              <span class="meta-label">Stars</span>
              <span class="meta-value">{project.stars}</span>
            </div>
          )}
          {project.language && (
            <div class="meta-block">
              <span class="meta-label">Language</span>
              <span class="meta-value">{project.language}</span>
            </div>
          )}
          {project.updatedAt && (
            <div class="meta-block">
              <span class="meta-label">Last updated</span>
              <span class="meta-value">{new Date(project.updatedAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
            </div>
          )}
          {latestRelease?.publishedAt && (
            <div class="meta-block">
              <span class="meta-label">Latest release</span>
              <span class="meta-value">{new Date(latestRelease.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
            </div>
          )}
        </div>

        <div class="signal-strip">
          {statusSignals.map((signal) => (
            <span class:list={["signal", signal.positive ? "signal-yes" : "signal-no"]}>{signal.label}</span>
          ))}
        </div>
      </aside>
    </section>

    {isDeprecated && (
      <div class="deprecated-notice">
        This tool has been archived or deprecated. Keep it as reference material, not as an active install recommendation.
      </div>
    )}

    {toolProof && (
      <RealityPanel
        verified={toolProof.verified}
        concept={toolProof.concept}
        proofs={toolProof.proofs}
      />
    )}

    {toolProof && (
      <TryItNow
        project={project}
        verified={toolProof.verified}
        concept={toolProof.concept}
        proofs={toolProof.proofs}
      />
    )}

    {project.screenshot && (
      <section class="tool-screenshot">
        <img src={project.screenshot} alt={`${project.name} screenshot`} loading="lazy" width="1280" />
        {project.screenshotType === "placeholder" && <span class="tool-screenshot__label">Preview</span>}
      </section>
    )}

    {(project.goodFor || project.notFor) && (
      <section class="fit-section">
        {project.goodFor && (
          <div class="fit-col">
            <h2>Good for</h2>
            <ul>
              {project.goodFor.map((item: string) => <li>{item}</li>)}
            </ul>
          </div>
        )}
        {project.notFor && (
          <div class="fit-col">
            <h2>Not for</h2>
            <ul>
              {project.notFor.map((item: string) => <li>{item}</li>)}
            </ul>
          </div>
        )}
      </section>
    )}

    {project.tags && project.tags.length > 0 && (
      <section class="tool-tags">
        {project.tags.map((tag: string) => <span class="tag">{tag}</span>)}
      </section>
    )}

    {showProof && proofData && snapshot && <PublicProof proofData={proofData} snapshot={snapshot} />}

    {related.length > 0 && (
      <section class="related-section">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Related dossiers</p>
            <h2 class="section-shell__title">Nearby tools</h2>
          </div>
        </div>
        <div class="related-grid">
          {related.map((candidate: any) => (
            <a href={`/tools/${candidate.repo}/`} class="related-item">
              <span class="related-name">{candidate.name}</span>
              <span class="related-desc">{candidate.tagline || candidate.description}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .tool-profile {
    display: grid;
    gap: 1.5rem;
  }

  .back-link {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .tool-profile__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      var(--color-surface);
  }

  .tool-profile__lead {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .tool-profile__lead h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4vw, 4rem);
    letter-spacing: -0.05em;
  }

  .tool-profile__lede {
    color: var(--color-text-muted);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .tool-profile__body {
    color: var(--color-text-dim);
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .tool-profile__badges,
  .signal-strip,
  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tool-profile__side {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .deprecated-notice {
    padding: 0.95rem 1rem;
    border: 1px solid rgba(217, 107, 59, 0.24);
    border-radius: var(--radius);
    background: rgba(217, 107, 59, 0.08);
    color: var(--color-text-muted);
  }

  .tool-screenshot {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
  }

  .tool-screenshot__label {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
  }

  .fit-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
  }

  .fit-col {
    display: grid;
    gap: 0.75rem;
  }

  .fit-col h2 {
    font-size: 1rem;
  }

  .fit-col ul {
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  .fit-col li + li {
    margin-top: 0.35rem;
  }

  @media (max-width: 900px) {
    .tool-profile__hero,
    .fit-section {
      grid-template-columns: 1fr;
    }
  }
</style>
