---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import MarketplaceCard from "../../components/MarketplaceCard.astro";
import { getMarketplaceContent, getPublishedCompareHref, getRelatedTools, getToolDossier } from "../../lib/content/marketplace.ts";
import { getProofData } from "../../lib/marketir/loader.mjs";
import { withBase } from "../../lib/site-paths";

export function getStaticPaths() {
  return getMarketplaceContent().catalog.all.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const tool = getToolDossier(Astro.params.slug || "");
if (!tool) {
  throw new Error(`Unknown tool dossier: ${Astro.params.slug}`);
}

const proofData = getProofData(tool.slug);
const related = getRelatedTools(tool.slug);
---

<Base title={`${tool.name} - DemumuMind MCP`} description={tool.description} currentPath={`/tools/${tool.slug}/`}>
  <div class="tool-profile">
    <a href={withBase("/tools/")} class="back-link">&larr; Back to tools</a>

    <section class="tool-profile__hero">
      <div class="tool-profile__lead">
        <p class="eyebrow">{tool.primaryCategoryTitle}</p>
        <h1>{tool.name}</h1>
        <p class="tool-profile__lede">{tool.summary}</p>
        <p class="tool-profile__body">{tool.description}</p>

        <div class="tool-profile__badges">
          <span class="badge badge-kind">{tool.kind}</span>
          <span class="badge badge-registered">{tool.pricing}</span>
          <span class:list={["badge", tool.quality.verified ? "badge-stable" : "badge-beta"]}>
            {tool.quality.verified ? "Verified" : tool.quality.label}
          </span>
          <span class="badge badge-kind">{tool.freshnessLabel}</span>
        </div>

        <div class="tool-links">
          <a href={tool.primaryActionUrl} class="btn btn-primary" rel="noopener noreferrer">Open docs</a>
          {tool.repoUrl && <a href={tool.repoUrl} class="btn btn-secondary" rel="noopener noreferrer">GitHub</a>}
          {tool.releaseTag && tool.repoUrl && <a href={`${tool.repoUrl}/releases`} class="btn btn-secondary" rel="noopener noreferrer">Releases</a>}
        </div>
      </div>

      <aside class="tool-profile__side">
        <div class="tool-meta-grid">
          <div class="meta-block">
            <span class="meta-label">Quality score</span>
            <span class="meta-value">{tool.quality.score}</span>
          </div>
          <div class="meta-block">
            <span class="meta-label">Category</span>
            <span class="meta-value">{tool.primaryCategoryTitle}</span>
          </div>
          <div class="meta-block">
            <span class="meta-label">Language</span>
            <span class="meta-value">{tool.language}</span>
          </div>
          <div class="meta-block">
            <span class="meta-label">Stars</span>
            <span class="meta-value">{tool.stars}</span>
          </div>
        </div>

        <div class="signal-strip">
          {tool.compatibility.platforms.map((platform) => (
            <span class="signal signal-yes">{platform.title}</span>
          ))}
        </div>
      </aside>
    </section>

    <section class="section-split">
      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Adoption</p>
            <h2 class="section-shell__title">What this tool is good for</h2>
          </div>
        </div>
        {tool.goodFor.length > 0 ? (
          <ul class="ops-list">
            {tool.goodFor.map((item) => <li>{item}</li>)}
          </ul>
        ) : (
          <div class="empty-state">Use the docs and compatibility notes above to judge whether this tool fits your workflow.</div>
        )}
      </div>

      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Compatibility</p>
            <h2 class="section-shell__title">Client, transport, and runtime fit</h2>
          </div>
        </div>
        <ul class="ops-list">
          {tool.compatibility.platforms.map((platform) => <li>Platform: {platform.title}</li>)}
          {tool.compatibility.transports.map((transport) => <li>Transport: {transport}</li>)}
          {tool.compatibility.runtimeSignals.map((runtime) => <li>Runtime: {runtime}</li>)}
        </ul>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
          <div>
            <p class="section-kicker">Limits</p>
            <h2 class="section-shell__title">What to check before rollout</h2>
          </div>
        </div>
      {tool.notFor.length > 0 ? (
        <ul class="ops-list">
          {tool.notFor.map((item) => <li>{item}</li>)}
        </ul>
      ) : (
        <div class="empty-state">This page does not include explicit limits yet. Check the docs and issue tracker before using the tool in production.</div>
      )}
    </section>

    <section class="section-split">
      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Adoption path</p>
            <h2 class="section-shell__title">How to try it</h2>
          </div>
        </div>
        <div class="launch-panel__card">
          {tool.install ? (
            <div class="launch-panel__command">
              <code>{tool.install}</code>
            </div>
          ) : (
            <p class="launch-panel__note">No direct install command is published. Use the docs or homepage to see the current setup path.</p>
          )}
          <div class="tool-links">
            {tool.docsUrl && <a href={tool.docsUrl} class="btn btn-secondary" rel="noopener noreferrer">Docs</a>}
            {tool.homepage && <a href={tool.homepage} class="btn btn-secondary" rel="noopener noreferrer">Homepage</a>}
          </div>
        </div>
      </div>

      <div class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Quality breakdown</p>
            <h2 class="section-shell__title">Score breakdown</h2>
          </div>
        </div>
        <div class="stats-grid">
          {Object.entries(tool.quality.breakdown).map(([label, value]) => (
            <div class="metric-card">
              <span class="metric-card__label">{label}</span>
              <strong class="metric-card__value">{value}</strong>
            </div>
          ))}
        </div>
      </div>
    </section>

    {proofData && (
      <section class="section-shell" data-proof-section>
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Public Proof</p>
            <h2 class="section-shell__title">Claims and evidence visible to the public</h2>
          </div>
        </div>
        {proofData.proven.length > 0 ? (
          <ul class="ops-list">
            {proofData.proven.map((claim) => <li>{claim.statement}</li>)}
          </ul>
        ) : (
          <div class="empty-state">No proven claims are published yet. Review the docs, releases, and repository activity before rollout.</div>
        )}
        {proofData.antiClaims.length > 0 && (
          <>
            <div class="section-shell__header">
              <div>
                <p class="section-kicker">Not Claimed</p>
                <h3 class="section-shell__title">Capabilities intentionally not promised</h3>
              </div>
            </div>
            <ul class="ops-list">
              {proofData.antiClaims.map((claim) => <li>{claim}</li>)}
            </ul>
          </>
        )}
      </section>
    )}

    {tool.screenshot && (
      <section class="tool-screenshot">
        <img src={withBase(tool.screenshot)} alt={`${tool.name} preview`} loading="lazy" width="1280" />
      </section>
    )}

    {related.length > 0 && (
      <section class="section-shell">
        <div class="section-shell__header">
          <div>
            <p class="section-kicker">Alternatives</p>
            <h2 class="section-shell__title">Nearby tools to compare next</h2>
          </div>
        </div>
        <div class="featured-tools-grid">
          {related.map((match) => (
            <div class="marketplace-related-stack">
              <MarketplaceCard entry={match.entry} compact />
              <div class="marketplace-related-stack__footer">
                <span class="results-count">{match.reason}</span>
                <a href={withBase(getPublishedCompareHref(tool.slug, match.entry.slug))} class="btn btn-secondary">Compare</a>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</Base>
