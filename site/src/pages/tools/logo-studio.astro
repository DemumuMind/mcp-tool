---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/site-paths";

const repoUrl = "https://github.com/DemumuMind/mcpt-logo-studio";
const npmUrl = "https://www.npmjs.com/package/@demumumind/logo-studio";
---

<Base
  title="Logo Studio - DemumuMind"
  description="Semantic product mining, encoder-aware prompt compilation, and diffusion logo generation. Professional logos, free, for everyone."
  currentPath="/tools/logo-studio/"
>
  <div class="tool-profile">
    <div class="breadcrumbs">
      <a href={withBase("/tools/")}>Registry</a>
      <span>/</span>
      <span>Logo Studio</span>
    </div>

    <section class="tool-profile__hero">
      <div class="tool-profile__lead">
        <p class="eyebrow">Tool dossier</p>
        <h1>Logo Studio</h1>
        <p class="tool-profile__lede">
          Semantic product mining, encoder-aware prompt compilation, and diffusion logo generation.
        </p>
        <p class="tool-profile__body">
          Feed it a product name and description. The mining engine extracts differentiating metaphors, the compiler builds token-budgeted prompts, and pluggable backends generate brand marks without pushing the workflow into a cloud-only design stack.
        </p>

        <div class="tool-profile__badges">
          <span class="badge badge-beta">beta</span>
          <span class="badge badge-kind">library</span>
          <span class="badge badge-kind">TypeScript</span>
        </div>

        <div class="tool-links">
          <a href={repoUrl} class="btn btn-primary" rel="noopener">View on GitHub</a>
          <a href={npmUrl} class="btn btn-secondary" rel="noopener">npm</a>
          <a href={`${repoUrl}/issues`} class="btn btn-secondary" rel="noopener">Issues</a>
        </div>
      </div>

      <aside class="tool-profile__side">
        <div class="tool-meta-grid">
          <div class="meta-block">
            <span class="meta-label">Language</span>
            <span class="meta-value">TypeScript</span>
          </div>
          <div class="meta-block">
            <span class="meta-label">License</span>
            <span class="meta-value">MIT</span>
          </div>
          <div class="meta-block">
            <span class="meta-label">Version</span>
            <span class="meta-value">0.2.0</span>
          </div>
        </div>

        <div class="signal-strip">
          <span class="signal signal-yes">npm published</span>
          <span class="signal signal-yes">Install path</span>
          <span class="signal signal-yes">Quick start</span>
          <span class="signal signal-yes">Has releases</span>
        </div>
      </aside>
    </section>

    <section class="tool-screenshot">
      <img
        src={withBase("/screenshots/logo-studio.png")}
        alt="Logo generated by Logo Studio"
        loading="lazy"
        width="720"
      />
      <span class="tool-screenshot__label badge badge-kind">Generated output</span>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Install</p>
          <h2 class="section-shell__title">Package entry point</h2>
        </div>
      </div>
      <div class="steps-box install-panel">
        <code id="install-cmd">npm install @demumumind/logo-studio</code>
        <button class="btn btn-secondary copy-btn" id="copy-install" aria-label="Copy install command">Copy install command</button>
      </div>
    </section>

    <section class="fit-section">
      <div class="fit-col">
        <h2>Good for</h2>
        <ul>
          <li>Generating brand marks from a product description alone.</li>
          <li>Switching between raw, studio, and README-driven prompt modes.</li>
          <li>Respecting CLIP and T5 token budgets instead of blindly over-prompting.</li>
          <li>Running against ComfyUI, Together AI, or local diffusers.</li>
        </ul>
      </div>
      <div class="fit-col">
        <h2>Not for</h2>
        <ul>
          <li>General image generation outside logo-specific workflows.</li>
          <li>Typography-heavy brand systems with no human review.</li>
          <li>Final identity work that skips designer QA.</li>
        </ul>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Quick start</p>
          <h2 class="section-shell__title">Basic flow</h2>
        </div>
      </div>
      <div class="schema-block">
        <pre><code>{`import { mine, compile, generate } from "@demumumind/logo-studio";

const mined = await mine({
  name: "Acme Corp",
  description: "We build bridges between legacy systems and modern cloud.",
  industry: "enterprise software",
});

const prompts = compile(mined, { promptMode: "studio" });

const result = await generate(prompts[0], {
  backend: "comfyui",
  seed: 42,
  width: 1024,
  height: 1024,
});`}</code></pre>
      </div>
    </section>

    <section class="section-shell">
      <div class="section-shell__header">
        <div>
          <p class="section-kicker">Pipeline</p>
          <h2 class="section-shell__title">How it works</h2>
        </div>
      </div>
      <div class="steps-box">
        <ol>
          <li>Mine visual anchors and differentiators from the product description.</li>
          <li>Compile encoder-aware prompts with token budgets and negative prompts.</li>
          <li>Generate through ComfyUI, Together AI, or a local diffusers bridge.</li>
        </ol>
      </div>
    </section>

    <div class="tool-tags">
      <span class="tag">diffusion</span>
      <span class="tag">logo-gen</span>
      <span class="tag">clip</span>
      <span class="tag">prompt-engineering</span>
      <span class="tag">comfyui</span>
      <span class="tag">sdxl</span>
    </div>
  </div>
</Base>

<script>
  const copyButton = document.getElementById("copy-install");
  const installCommand = document.getElementById("install-cmd");

  if (copyButton && installCommand) {
    copyButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(installCommand.textContent || "");
        copyButton.textContent = "Copied!";
        setTimeout(() => {
          copyButton.textContent = "Copy install command";
        }, 1500);
      } catch {
        copyButton.textContent = "Copy failed";
        setTimeout(() => {
          copyButton.textContent = "Copy install command";
        }, 1500);
      }
    });
  }
</script>

<style>
  .tool-profile {
    display: grid;
    gap: 1.5rem;
  }

  .tool-profile > *,
  .tool-profile__hero,
  .tool-profile__lead,
  .tool-profile__side,
  .section-shell,
  .schema-block,
  .install-panel {
    min-width: 0;
  }

  .tool-profile__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      var(--color-surface);
  }

  .tool-profile__lead {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .tool-profile__lead h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4vw, 4rem);
    letter-spacing: -0.05em;
  }

  .tool-profile__lede {
    color: var(--color-text-muted);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .tool-profile__body {
    color: var(--color-text-dim);
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .tool-profile__badges,
  .signal-strip,
  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tool-profile__side {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .tool-screenshot {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
  }

  .tool-screenshot__label {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
  }

  .install-panel {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 1rem;
  }

  .install-panel code {
    min-width: 0;
    max-width: 100%;
    overflow-x: auto;
    white-space: nowrap;
  }

  .fit-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
  }

  .fit-col {
    display: grid;
    gap: 0.75rem;
  }

  .fit-col h2 {
    font-size: 1rem;
  }

  .fit-col ul {
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  .fit-col li + li {
    margin-top: 0.35rem;
  }

  @media (max-width: 900px) {
    .tool-profile__hero,
    .fit-section {
      grid-template-columns: 1fr;
    }

    .install-panel {
      align-items: flex-start;
    }
  }
</style>
