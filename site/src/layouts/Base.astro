---
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
import "@fontsource/manrope/700.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/sora/500.css";
import "@fontsource/sora/600.css";
import "@fontsource/sora/700.css";
import registryMeta from "../data/registry/meta.json";
import { kit } from "../lib/kit";
import { withBase } from "../lib/site-paths";

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  ogImage?: string;
  routeFamily?: "brand" | "catalog" | "reference" | "ops" | "utility";
  pageClass?: string;
}

function inferRouteFamily(currentPath: string): Props["routeFamily"] {
  if (!currentPath || currentPath === "/404/") return "utility";
  if (
    currentPath === "/" ||
    currentPath.startsWith("/tools/") ||
    currentPath.startsWith("/compare/") ||
    currentPath.startsWith("/categories/") ||
    currentPath.startsWith("/platforms/") ||
    currentPath.startsWith("/collections/")
  ) {
    return "catalog";
  }
  if (
    currentPath.startsWith("/docs/") ||
    currentPath.startsWith("/faq/") ||
    currentPath.startsWith("/methodology/") ||
    currentPath.startsWith("/terms/") ||
    currentPath.startsWith("/privacy/") ||
    currentPath.startsWith("/about/") ||
    currentPath.startsWith("/request-category/") ||
    currentPath.startsWith("/submit/") ||
    currentPath.startsWith("/stats/") ||
    currentPath.startsWith("/trust/") ||
    currentPath.startsWith("/press/") ||
    currentPath.startsWith("/releases/") ||
    currentPath.startsWith("/start/") ||
    currentPath.startsWith("/support/") ||
    currentPath.startsWith("/newsletter/")
  ) {
    return "reference";
  }
  if (currentPath.startsWith("/lab/")) return "ops";
  return "brand";
}

function isActivePath(currentPath: string, href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href);
}

const {
  title,
  description = kit.site.description || "DemumuMind MCP is a public marketplace for browsing, comparing, and evaluating MCP tools.",
  currentPath = "",
  ogImage,
  routeFamily: routeFamilyProp,
  pageClass = "",
} = Astro.props;

const siteUrl = kit.site.url || "https://example.invalid/";
const canonicalPath = currentPath.startsWith("/") ? currentPath.slice(1) : currentPath;
const canonicalUrl = new URL(canonicalPath || "", siteUrl).href;
const ogImagePath = ogImage?.startsWith("/") ? ogImage.slice(1) : ogImage;
const ogImageUrl = ogImagePath ? new URL(ogImagePath, siteUrl).href : undefined;
const routeFamily = routeFamilyProp || inferRouteFamily(currentPath);

const primaryNavLinks = [
  { href: "/", label: "Home" },
  { href: "/tools/", label: "Browse Tools" },
  { href: "/compare/", label: "Compare" },
  { href: "/categories/", label: "Categories" },
  { href: "/docs/", label: "Docs" },
  { href: "/stats/", label: "Stats" },
  { href: "/faq/", label: "FAQ" },
];

const secondaryNavLinks = [
  { href: "/platforms/", label: "Platforms" },
  { href: "/collections/", label: "Collections" },
  { href: "/tools/presets/", label: "Presets" },
  { href: "/submit/", label: "Submit" },
  { href: "/request-category/", label: "Request Category" },
  { href: "/methodology/", label: "Methodology" },
  { href: "/about/", label: "About" },
  { href: "/privacy/", label: "Privacy" },
];

const meta = registryMeta as any;
const schemaLabel = meta.schemaVersion ? `Schema ${meta.schemaVersion}` : null;
const syncDate = meta.lastSyncAt
  ? new Date(meta.lastSyncAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{title}</title>
  </head>
  <body class:list={["site-shell", pageClass]} data-route-family={routeFamily}>
    <header class="site-nav">
      <div class="site-nav__inner">
        <a href={withBase("/")} class="site-brand">
          <span class="site-brand__kicker">{kit.site.title || "DemumuMind MCP"}</span>
          <span class="site-brand__title">MCP Tool Shop</span>
        </a>

        <nav class="site-nav__primary" aria-label="Primary">
          <ul class="nav-links">
            {primaryNavLinks.map((link) => (
              <li>
                <a href={withBase(link.href)} class="nav-link" aria-current={isActivePath(currentPath, link.href) ? "page" : undefined}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="site-nav__meta">
          <span>Checked listings</span>
          <span>Clear compatibility</span>
          <a href={withBase("/submit/")} class="site-nav__submit">Submit a Tool</a>
        </div>
      </div>
    </header>

    <main class="site-main">
      <div class="page-frame">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__intro">
          <span class="footer-kicker">{kit.site.title || "DemumuMind MCP"}</span>
          <p>
            Browse MCP tools with the context you need to make a call faster: what they do, where they fit, and how mature they look.
          </p>
        </div>

        <div class="site-footer__nav">
          <div>
            <h2>Marketplace</h2>
            <ul>
              {primaryNavLinks.map((link) => (
                <li><a href={withBase(link.href)}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h2>Reference</h2>
            <ul>
              {secondaryNavLinks.map((link) => (
                <li><a href={withBase(link.href)}>{link.label}</a></li>
              ))}
              <li><a href={kit.org.url || "https://github.com/DemumuMind"} rel="noopener">GitHub Org</a></li>
            </ul>
          </div>
        </div>

        <div class="site-footer__meta">
          {schemaLabel && <span>{schemaLabel}</span>}
          {syncDate && <span>Updated on {syncDate}</span>}
          <span>Published by DemumuMind</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
