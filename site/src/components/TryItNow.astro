---
interface Props {
  project: any;
  verified: boolean;
  concept: boolean;
  proofs: string[];
}

const { project, verified, concept, proofs = [] } = Astro.props;
const isCli = project.kind === "cli";
const isMcpServer = project.kind === "mcp-server";
const installCommand = project.install;
const repoUrl = `https://github.com/DemumuMind/${project.repo}`;

const showInstall = verified && (isCli || isMcpServer) && installCommand;
const showManual = verified && isMcpServer && !installCommand;
const showConcept = concept;
const conceptChecks = [
  { label: "CI pipeline", ready: proofs.includes("ci") },
  { label: "Project structure", ready: proofs.some((proof) => ["npm", "python", "cargo", "dotnet"].includes(proof)) },
  { label: "Design spec", ready: Boolean(project.description) },
];
---

<section class="launch-panel">
  {showInstall && (
    <div class="launch-panel__card">
      <div class="launch-panel__header">
        <div>
          <span class="launch-panel__eyebrow">Operator path</span>
          <h3>Try it now</h3>
        </div>
        <span class="launch-panel__hint">Run locally</span>
      </div>
      <div class="launch-panel__command">
        <code>{installCommand}</code>
        <button class="launch-panel__copy" data-clipboard-text={installCommand} aria-label="Copy command">Copy</button>
      </div>
      {isMcpServer && (
        <p class="launch-panel__note">
          This command starts the MCP server. Wire it into your client configuration after install.
        </p>
      )}
    </div>
  )}

  {showManual && (
    <div class="launch-panel__card">
      <div class="launch-panel__header">
        <div>
          <span class="launch-panel__eyebrow">Connection path</span>
          <h3>Connect server</h3>
        </div>
      </div>
      <p class="launch-panel__note">
        This MCP server needs manual configuration before it can be used from a client.
      </p>
      <a href={`${repoUrl}#readme`} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        View connection guide
      </a>
    </div>
  )}

  {showConcept && (
    <div class="launch-panel__card launch-panel__card--concept">
      <div class="launch-panel__header">
        <div>
          <span class="launch-panel__eyebrow">Readiness</span>
          <h3>Concept prototype</h3>
        </div>
        <span class="launch-panel__hint">Not packaged yet</span>
      </div>
      <p class="launch-panel__note">
        This project is still proving its install path. Explore the source or help shape the first stable release.
      </p>
      <ul class="launch-panel__checklist">
        {conceptChecks.map((item) => (
          <li class:list={[item.ready ? "launch-panel__check--ready" : "launch-panel__check--pending"]}>
            <span>{item.ready ? "OK" : "TODO"}</span>
            <span>{item.label}</span>
          </li>
        ))}
      </ul>
      <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
        Browse source
      </a>
    </div>
  )}
</section>

<script>
  document.querySelectorAll(".launch-panel__copy").forEach((button) => {
    button.addEventListener("click", async () => {
      const text = button.getAttribute("data-clipboard-text");
      if (!text) return;

      try {
        await navigator.clipboard.writeText(text);
        const originalLabel = button.textContent;
        button.textContent = "Copied";
        setTimeout(() => {
          button.textContent = originalLabel;
        }, 1600);
      } catch {
        button.textContent = "Failed";
        setTimeout(() => {
          button.textContent = "Copy";
        }, 1600);
      }
    });
  });
</script>

<style>
  .launch-panel {
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .launch-panel__card {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
      var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .launch-panel__card--concept {
    border-color: rgba(217, 107, 59, 0.24);
  }

  .launch-panel__header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .launch-panel__eyebrow,
  .launch-panel__hint {
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.69rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .launch-panel__eyebrow {
    display: block;
    margin-bottom: 0.3rem;
  }

  .launch-panel h3 {
    margin: 0;
    font-size: 1.08rem;
    color: var(--color-text);
  }

  .launch-panel__command {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    min-height: 3rem;
    padding: 0.85rem 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.22);
  }

  .launch-panel__command code {
    flex: 1;
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--color-signal);
    white-space: nowrap;
    overflow-x: auto;
  }

  .launch-panel__copy {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text-muted);
    min-height: 2.2rem;
    padding: 0 0.9rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .launch-panel__copy:hover {
    color: var(--color-text);
    border-color: rgba(215, 255, 63, 0.24);
  }

  .launch-panel__note {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .launch-panel__checklist {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .launch-panel__checklist li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.65rem;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.55rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-text-muted);
    font-size: 0.84rem;
  }

  .launch-panel__checklist li span:first-child {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .launch-panel__check--ready span:first-child {
    color: var(--color-success);
  }

  .launch-panel__check--pending span:first-child {
    color: var(--color-warning);
  }

  @media (max-width: 720px) {
    .launch-panel__header,
    .launch-panel__command {
      flex-direction: column;
      align-items: flex-start;
    }

    .launch-panel__copy {
      width: 100%;
    }
  }
</style>
