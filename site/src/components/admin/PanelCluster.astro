---
import type { AdminPanel } from "./content";

interface Props {
  items: AdminPanel[];
}

const { items } = Astro.props;
---

<section class="admin-panel-grid">
  {items.map((item) => (
    <article class="admin-panel reveal-stage">
      <div class="admin-panel__header">
        <span class="admin-panel__kicker">{item.kicker}</span>
        <h2>{item.title}</h2>
      </div>
      <p class="admin-panel__summary">{item.summary}</p>
      <ul>
        {item.bullets.map((bullet) => (
          <li>{bullet}</li>
        ))}
      </ul>
    </article>
  ))}
</section>

<style>
  .admin-panel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .admin-panel {
    display: grid;
    gap: 0.85rem;
    padding: 1.05rem;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.012)),
      rgba(13, 17, 22, 0.88);
  }

  .admin-panel__header {
    display: grid;
    gap: 0.35rem;
  }

  .admin-panel__header h2 {
    font-size: 1.18rem;
    letter-spacing: -0.04em;
  }

  .admin-panel__kicker {
    color: var(--color-signal);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .admin-panel__summary,
  .admin-panel li {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .admin-panel ul {
    margin: 0;
    padding-left: 1.15rem;
    display: grid;
    gap: 0.55rem;
  }
</style>
