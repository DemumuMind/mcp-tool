---
import StatusPill from "./StatusPill.astro";

interface Props {
  badge: string;
  eyebrow: string;
  title: string;
  lede: string;
  meta: string[];
}

const { badge, eyebrow, title, lede, meta } = Astro.props;
---

<section class="admin-hero reveal-stage">
  <div class="admin-hero__topline">
    <StatusPill label={badge} tone="system" />
    <span class="admin-hero__eyebrow">{eyebrow}</span>
  </div>
  <div class="admin-hero__body">
    <div class="admin-hero__copy">
      <h1>{title}</h1>
      <p>{lede}</p>
    </div>
    <div class="admin-hero__meta">
      {meta.map((item) => (
        <div class="admin-hero__meta-item">
          <span>{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .admin-hero {
    display: grid;
    gap: 1rem;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(circle at top left, rgba(108, 224, 255, 0.16), transparent 28%),
      radial-gradient(circle at bottom right, rgba(122, 141, 255, 0.14), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      rgba(9, 12, 18, 0.86);
  }

  .admin-hero__topline,
  .admin-hero__body {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .admin-hero__eyebrow {
    padding-top: 0.35rem;
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .admin-hero__copy {
    display: grid;
    gap: 0.75rem;
    max-width: 44rem;
  }

  .admin-hero__copy h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    letter-spacing: -0.05em;
    line-height: 0.96;
  }

  .admin-hero__copy p {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .admin-hero__meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    min-width: min(100%, 24rem);
  }

  .admin-hero__meta-item {
    display: flex;
    align-items: center;
    min-height: 4rem;
    padding: 0.95rem 1rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
    font-size: 0.88rem;
  }

  @media (max-width: 720px) {
    .admin-hero__meta {
      grid-template-columns: 1fr;
      width: 100%;
    }
  }
</style>
